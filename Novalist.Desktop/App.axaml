            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.statusPopupLevel">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="3,0,0,0" />
        </Style>

        <Style Selector="TextBlock.statusPopupNA">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Focus Peek Styles ── -->
        <Style Selector="Border.focusPeekCard">
            <Setter Property="Width" Value="540" />
            <Setter Property="MaxHeight" Value="420" />
            <Setter Property="Background" Value="{DynamicResource EditorBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusXLarge}" />
            <Setter Property="BoxShadow" Value="0 8 28 0 #4A000000" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="Border.focusPeekHeader">
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="StackPanel.focusPeekMain">
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="Grid.focusPeekBody">
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="StackPanel.focusPeekDetails">
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>

        <Style Selector="StackPanel.focusPeekImageArea">
            <Setter Property="Width" Value="120" />
        </Style>

        <Style Selector="Button.focusPeekAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
        </Style>
        <Style Selector="Button.focusPeekAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="TextBlock.focusPeekName">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxWidth" Value="260" />
        </Style>

        <Style Selector="Border.focusPeekBadge">
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.focusPeekBadgeText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="LetterSpacing" Value="0.4" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="ComboBox.focusPeekCompactCombo">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="MinHeight" Value="26" />
        </Style>

        <Style Selector="Border.focusPeekImageFrame">
            <Setter Property="Background" Value="{DynamicResource ExplorerBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MaxHeight" Value="240" />
        </Style>

        <Style Selector="Border.focusPeekPill">
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,5,5" />
        </Style>

        <Style Selector="Border.focusPeekPill TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Path.focusPeekPillIcon">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,1,0" />
        </Style>

        <Style Selector="Border.focusPeekSectionLine">
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="0,6,0,0" />
        </Style>

        <Style Selector="DockPanel.focusPeekCompactRow">
            <Setter Property="LastChildFill" Value="True" />
        </Style>

        <Style Selector="TextBlock.focusPeekSectionCaption">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="LetterSpacing" Value="0.4" />
        </Style>

        <Style Selector="TextBlock.focusPeekSectionValue">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="LineHeight" Value="16" />
        </Style>

        <Style Selector="TextBlock.focusPeekBodyText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="LineHeight" Value="17" />
        </Style>

        <Style Selector="TextBlock.focusPeekBodyTextItalic">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="LineHeight" Value="17" />
        </Style>

        <Style Selector="TextBlock.focusPeekDescription">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="LineHeight" Value="16" />
        </Style>

        <Style Selector="TextBlock.focusPeekRoleLabel">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
        </Style>

        <Style Selector="Button.focusPeekLinkButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
        </Style>
        <Style Selector="Button.focusPeekLinkButton:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBlock.focusPeekPropertyKey">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
        </Style>

        <Style Selector="TextBlock.focusPeekPropertyValue">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
        </Style>

        <Style Selector="StackPanel.focusPeekInlineProperty">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,0,10,3" />
        </Style>

        <Style Selector="TextBlock.focusPeekInlinePropertyKey">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style Selector="TextBlock.focusPeekInlinePropertyValue">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
        </Style>

        <Style Selector="Border.focusPeekSectionBody">
            <Setter Property="Background" Value="{DynamicResource ExplorerBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
            <Setter Property="Padding" Value="9,7" />
        </Style>

        <!-- Drop target -->
        <Style Selector="Border.dropTarget">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <!-- Primary button (generic) -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrushHover}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        </Style>

        <!-- Danger button (red destructive action — replaces ConfirmDialog's
             ad-hoc red foreground; consumers add Classes="danger" to a button
             to express "this deletes things"). -->
        <Style Selector="Button.danger">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <!-- Dialog button-row: standard layout for any dialog's bottom action
             strip. Use as: <StackPanel Classes="dialogButtonRow"> ... </StackPanel> -->
        <Style Selector="StackPanel.dialogButtonRow">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Spacing" Value="{DynamicResource SpacingMedium}" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>
        <Style Selector="StackPanel.dialogButtonRow > Button">
            <Setter Property="Padding" Value="16,8" />
        </Style>

        <!-- ── Timeline styles ── -->
        <Style Selector="Button.timelineToolbarBtn">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="Background" Value="{DynamicResource ExplorerBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.timelineToolbarBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <Style Selector="Button.timelineAddBtn">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.timelineAddBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1177BB" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        </Style>

        <Style Selector="ComboBox.timelineFilter">
            <Setter Property="MaxWidth" Value="160" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
        </Style>

        <Style Selector="Border.timelineEventCard">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="Border.timelineEventCard.noDate">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <Style Selector="Button.timelineEventActionBtn">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="Background" Value="{DynamicResource EditorBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
        </Style>
        <Style Selector="Button.timelineEventActionBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.timelineEventActionDanger:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#e74c3c" />
            <Setter Property="BorderBrush" Value="#e74c3c" />
        </Style>
        <!-- ── GridSplitter (thin themed separator) ── -->
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource RibbonBorder}" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="GridSplitter[ResizeDirection=Columns]">
            <Setter Property="Width" Value="1" />
        </Style>
        <Style Selector="GridSplitter[ResizeDirection=Rows]">
            <Setter Property="Height" Value="1" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme colors -->
                <ResourceInclude Source="avares://Novalist.Desktop/Assets/Themes/NovalistTheme.axaml" />
                <!-- Design tokens (spacing, radii, shadows, motion) -->
                <ResourceInclude Source="avares://Novalist.Desktop/Assets/Themes/DesignTokens.axaml" />
            </ResourceDictionary.MergedDictionaries>

