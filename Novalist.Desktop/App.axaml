<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Novalist.Desktop.Converters"
             x:Class="Novalist.Desktop.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <!-- Custom Styles -->

        <!-- ── NlvCard: standard card for panels, dashboards, overlays ── -->
        <Style Selector="Border.nlvCard">
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusXLarge}" />
            <Setter Property="Padding" Value="12,12" />
            <Setter Property="BoxShadow" Value="0 1 4 0 #14000000" />
        </Style>

        <!-- ── NlvButtonPrimary: main action button (accent-filled) ── -->
        <Style Selector="Button.nlvButtonPrimary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
        </Style>
        <Style Selector="Button.nlvButtonPrimary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrushHover}" />
        </Style>

        <!-- ── NlvButtonSecondary: subtle outlined button ── -->
        <Style Selector="Button.nlvButtonSecondary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
        </Style>
        <Style Selector="Button.nlvButtonSecondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ── NlvButtonGhost: minimal hover-only button ── -->
        <Style Selector="Button.nlvButtonGhost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
        </Style>
        <Style Selector="Button.nlvButtonGhost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <!-- ── NlvSectionHeader: consistent section titles in views ── -->
        <Style Selector="TextBlock.nlvSectionHeader">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeTitleSmall}" />
            <Setter Property="FontWeight" Value="{DynamicResource FontWeightTitle}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="Margin" Value="0,4,0,6" />
        </Style>

        <!-- ── compactNud: shrink the NumericUpDown spinner buttons so the text
             field stays usable in tight panels. Apply Classes="compactNud". ── -->
        <Style Selector="NumericUpDown.compactNud">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style Selector="NumericUpDown.compactNud /template/ ButtonSpinner">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MaxHeight" Value="24" />
        </Style>
        <Style Selector="NumericUpDown.compactNud /template/ ButtonSpinner /template/ RepeatButton">
            <Setter Property="Width" Value="16" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="Height" Value="11" />
            <Setter Property="MinHeight" Value="11" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeTiny}" />
        </Style>
        <Style Selector="NumericUpDown.compactNud /template/ ButtonSpinner /template/ RepeatButton /template/ ContentPresenter">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="NumericUpDown.compactNud /template/ ButtonSpinner /template/ RepeatButton PathIcon">
            <Setter Property="Width" Value="6" />
            <Setter Property="Height" Value="6" />
        </Style>
        <Style Selector="NumericUpDown.compactNud /template/ TextBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <!-- ── NlvCaptionLabel: small labels above inputs/cards ── -->
        <Style Selector="TextBlock.nlvCaptionLabel">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="LetterSpacing" Value="0.6" />
        </Style>

        <!-- ── App Bar (slim, replaces ribbon) ── -->
        <Style Selector="Border.appBar">
            <Setter Property="Background" Value="{DynamicResource RibbonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="4,0,6,0" />
        </Style>
        <Style Selector="Button.appBarButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.appBarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>
        <Style Selector="Button.appBarBookPicker">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>

        <!-- ── Activity Bar (leftmost icon column) ── -->
        <Style Selector="Border.activityBar">
            <Setter Property="Background" Value="{DynamicResource ActivityBarBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonBorder}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="Button.activityBarButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusNone}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.activityBarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>
        <Style Selector="Button.activityBarButton.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.activityBarButton.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
        </Style>
        <Style Selector="Viewbox.activityBarIcon">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
        </Style>
        <Style Selector="Path.activityBarIconPath">
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stroke" Value="{DynamicResource DimText}" />
        </Style>
        <Style Selector="Button.activityBarButton:pointerover Path.activityBarIconPath">
            <Setter Property="Stroke" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.activityBarButton.active Path.activityBarIconPath">
            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ── Ribbon Old Button (backward compat for any extension using ribbonButton class) ── -->
        <!-- ── Codex Filter Pill (lightweight filter chip for Codex hub) ── -->
        <Style Selector="Button.codexFilterPill">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusPill}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.codexFilterPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.codexFilterPill.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- ── Panel Toggle Button (VS Code-style header buttons) ── -->
        <Style Selector="Button.panelToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.panelToggleButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>
        <Style Selector="Button.panelToggleButton.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
        </Style>
        <Style Selector="Viewbox.panelToggleIcon">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
        </Style>
        <Style Selector="Path.panelToggleIcon">
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stroke" Value="{DynamicResource DimText}" />
        </Style>
        <Style Selector="Button.panelToggleButton:pointerover Path.panelToggleIcon">
            <Setter Property="Stroke" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.panelToggleButton.active Path.panelToggleIcon">
            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ── Start Menu Panel (File-style backstage) ── -->
        <Style Selector="Border.startMenuPanel">
            <Setter Property="Background" Value="{DynamicResource RibbonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonBorder}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="Button.startMenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusNone}" />
        </Style>
        <Style Selector="Button.startMenuItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <!-- ── Ribbon Vector Icon (kept for start menu icons) ── -->
        <Style Selector="Path.ribbonIcon">
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stroke" Value="{DynamicResource NormalText}" />
        </Style>

        <!-- Small inline icon (for tabs, lists, badges) -->
        <Style Selector="Viewbox.inlineIcon">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
        </Style>
        <Style Selector="Path.inlineIcon">
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stroke" Value="{DynamicResource NormalText}" />
        </Style>

        <!-- ── Editor Toolbar ── -->
        <Style Selector="Border.editorToolbar">
            <Setter Property="Background" Value="{DynamicResource EditorBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Button.editorToolbarButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style Selector="Button.editorToolbarButton.active">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="Button.editorToolbarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="Button.editorToolbarButton.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
        </Style>

        <Style Selector="TextBlock.editorToolbarGlyph">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodyLarge}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.editorToolbarSeparator">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Group Mode Button (segmented-style) ── -->
        <Style Selector="Button.groupModeButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusNone}" />
        </Style>
        <Style Selector="Button.groupModeButton.active">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.groupModeButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <!-- ── Explorer Tabs (left sidebar) ── -->
        <Style Selector="Button.explorerTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource DimText}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusNone}" />
        </Style>
        <Style Selector="Button.explorerTab.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>
        <Style Selector="Button.explorerTab:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <!-- ── Editor Tab Strip & Tabs (refined) ── -->
        <Style Selector="Border.editorTabStrip">
            <Setter Property="Background" Value="{DynamicResource TabStripBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EditorTabBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="Border.editorTabHost">
            <Setter Property="Background" Value="{DynamicResource EditorTabInactiveBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EditorTabBorder}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusNone}" />
        </Style>

        <Style Selector="Border.editorTabHost.active">
            <Setter Property="Background" Value="{DynamicResource EditorTabActiveBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0,2,1,0" />
        </Style>

        <Style Selector="Border.editorTabHost:pointerover">
            <Setter Property="Background" Value="{DynamicResource EditorTabHoverBackground}" />
        </Style>

        <Style Selector="Border.editorTabHost.active:pointerover">
            <Setter Property="Background" Value="{DynamicResource EditorTabActiveBackground}" />
        </Style>

        <Style Selector="Button.editorTabSurface">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10,8,9" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.editorTabSurface:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.editorTabCloseButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="0,7,8,7" />
            <Setter Property="MinWidth" Value="20" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style Selector="Button.editorTabCloseButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource EditorTabCloseHoverBackground}" />
        </Style>

        <Style Selector="Path.editorTabCloseGlyph">
            <Setter Property="Stroke" Value="{DynamicResource EditorTabCloseGlyph}" />
            <Setter Property="StrokeThickness" Value="1.35" />
            <Setter Property="StrokeLineCap" Value="Square" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Data" Value="M 1,1 L 8,8 M 8,1 L 1,8" />
        </Style>

        <Style Selector="Button.editorTabCloseButton:pointerover Path.editorTabCloseGlyph">
            <Setter Property="Stroke" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="Border.editorTabBadge">
            <Setter Property="Background" Value="{DynamicResource EditorTabBadgeBackground}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBlock.editorTabBadgeText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeTiny}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="LetterSpacing" Value="0.6" />
        </Style>

        <Style Selector="Border.editorTabHost TextBlock.editorTabText">
            <Setter Property="Foreground" Value="{DynamicResource EditorTabMutedForeground}" />
        </Style>

        <Style Selector="Border.editorTabHost.active TextBlock.editorTabText">
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="TextBlock.editorTabText">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="MaxWidth" Value="280" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.editorTabDirtyDot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusPill}" />
            <Setter Property="Background" Value="{DynamicResource DimText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Link Button ── -->
        <Style Selector="Button.linkButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.linkButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ── Welcome Screen Action Button ── -->
        <Style Selector="Button.welcomeAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="44" />
        </Style>
        <Style Selector="Button.welcomeAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- ── Relationship Controls ── -->
        <Style Selector="Button.relationshipBadgeRemove">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusPill}" />
        </Style>
        <Style Selector="Button.relationshipBadgeRemove:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="Button.relationshipRowRemove">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleText}" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}" />
        </Style>
        <Style Selector="Button.relationshipRowRemove:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
        </Style>

        <Style Selector="Border.relationshipSuggestionPanel">
            <Setter Property="Background" Value="{DynamicResource EditorBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RibbonGroupBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMedium}" />
            <Setter Property="BoxShadow" Value="0 6 18 0 #30000000" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="ListBox.relationshipSuggestionList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MaxHeight" Value="168" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style Selector="ListBox.relationshipSuggestionList ListBoxItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="{DynamicResource NormalText}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style Selector="ListBox.relationshipSuggestionList ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource TreeItemHover}" />
        </Style>

        <Style Selector="ListBox.relationshipSuggestionList ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource TreeItemSelected}" />
        </Style>

        <!-- ── Image Controls ── -->
        <Style Selector="Button.imageThumbButton">
