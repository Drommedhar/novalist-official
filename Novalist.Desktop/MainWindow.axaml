<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Novalist.Desktop.ViewModels"
        xmlns:views="using:Novalist.Desktop.Views"
        xmlns:m="using:Novalist.Core.Models"
        xmlns:loc="using:Novalist.Desktop.Localization"
        xmlns:sdk="using:Novalist.Sdk.Models"
        xmlns:conv="using:Novalist.Desktop.Converters"
        mc:Ignorable="d"
        d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="Novalist.Desktop.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Panel>
    <DockPanel>
        <!-- Ribbon Bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource RibbonBackground}"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsProjectLoaded}">
            <StackPanel>
                <!-- Ribbon Tabs -->
                <StackPanel x:Name="RibbonTabRow" Orientation="Horizontal" Margin="0,0,0,0">
                    <!-- Start (File-style) button — distinct styling -->
                    <Button Content="{loc:Loc ribbon.start}"
                            Command="{Binding ToggleStartMenuCommand}"
                            Classes="ribbonFileTab" />

                    <Button Content="{loc:Loc ribbon.edit}"
                            Command="{Binding SetActiveTabCommand}"
                            CommandParameter="Edit"
                            Classes="ribbonTab"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Edit}" />
                    <Button Content="{loc:Loc ribbon.view}"
                            Command="{Binding SetActiveTabCommand}"
                            CommandParameter="View"
                            Classes="ribbonTab"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=View}" />
                    <Button Content="{loc:Loc ribbon.extensions}"
                            Command="{Binding SetActiveTabCommand}"
                            CommandParameter="Extensions"
                            Classes="ribbonTab"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Extensions}" />
                </StackPanel>

                <!-- ═══ Edit Tab Content ═══ -->
                <Border Classes="ribbonContent"
                        IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Edit}">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <!-- Create Group -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding Explorer.CreateChapterCommand}"
                                            Classes="ribbonButtonLarge"
                                            ToolTip.Tip="{loc:Loc ribbon.chapterTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconBook}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.chapter}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding Explorer.CreateSceneCommand}"
                                            Classes="ribbonButtonLarge"
                                            ToolTip.Tip="{loc:Loc ribbon.sceneTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconFileText}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.scene}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.create}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Text Formatting Group (visible when editor has a doc open) -->
                        <Border Classes="ribbonGroup"
                                IsVisible="{Binding Editor.IsDocumentOpen}">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="2"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding Editor.ToggleBoldCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsBoldActive}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.boldTooltip}">
                                        <TextBlock Text="B" FontWeight="Bold" FontSize="14" />
                                    </Button>
                                    <Button Command="{Binding Editor.ToggleItalicCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsItalicActive}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.italicTooltip}">
                                        <TextBlock Text="I" FontStyle="Italic" FontSize="14" />
                                    </Button>
                                    <Button Command="{Binding Editor.ToggleUnderlineCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsUnderlineActive}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.underlineTooltip}">
                                        <TextBlock Text="U" TextDecorations="Underline" FontSize="14" />
                                    </Button>

                                    <Border Classes="ribbonSeparator" />

                                    <Button Command="{Binding Editor.AlignLeftCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsAlignLeft}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.alignLeftTooltip}">
                                        <TextBlock Text="☰" FontSize="14" />
                                    </Button>
                                    <Button Command="{Binding Editor.AlignCenterCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsAlignCenter}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.alignCenterTooltip}">
                                        <TextBlock Text="☷" FontSize="14" />
                                    </Button>
                                    <Button Command="{Binding Editor.AlignRightCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsAlignRight}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.alignRightTooltip}">
                                        <TextBlock Text="☵" FontSize="14" />
                                    </Button>
                                    <Button Command="{Binding Editor.AlignJustifyCommand}"
                                            Classes="ribbonButtonSmall"
                                            Classes.active="{Binding Editor.IsAlignJustify}"
                                            Focusable="False"
                                            ToolTip.Tip="{loc:Loc editor.alignJustifyTooltip}">
                                        <TextBlock Text="☱" FontSize="14" />
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.font}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Book Switcher Group -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ToggleBookPickerCommand}"
                                            Classes="ribbonButtonSmall"
                                            MinWidth="140"
                                            MaxWidth="220"
                                            Padding="8,6"
                                            FontSize="12"
                                            HorizontalContentAlignment="Stretch"
                                            ToolTip.Tip="{loc:Loc book.pickerTooltip}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Viewbox Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Classes="ribbonIcon" Data="{StaticResource IconBook}"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ActiveBook.Name, FallbackValue=''}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="▾"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       Opacity="0.7" />
                                        </Grid>
                                    </Button>
                                    <Button Content="{loc:Loc book.addBook}"
                                            Command="{Binding AddBookCommand}"
                                            Classes="ribbonButtonSmall"
                                            Padding="8,6" FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc book.switcherLabel}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ View Tab Content ═══ -->
                <Border Classes="ribbonContent"
                        IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=View}">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <!-- Views Group (main content views) -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ShowDashboardCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Dashboard}"
                                            ToolTip.Tip="{loc:Loc ribbon.dashboardTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconBarChart}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.dashboard}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ShowTimelineCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Timeline}"
                                            ToolTip.Tip="{loc:Loc ribbon.timelineTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconCalendar}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.timeline}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ShowCodexHubCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=CodexHub}"
                                            ToolTip.Tip="{loc:Loc ribbon.codexHubTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconBookOpen}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.codexHub}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ShowManuscriptCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Manuscript}"
                                            ToolTip.Tip="{loc:Loc ribbon.manuscriptTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconScroll}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.manuscript}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.views}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Sidebars Group (toggle visibility of side panels) -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ToggleExplorerCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding IsExplorerVisible}"
                                            ToolTip.Tip="{loc:Loc ribbon.explorerTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconFolder}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.explorer}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ToggleContextSidebarCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding IsContextSidebarVisible}"
                                            ToolTip.Tip="{loc:Loc ribbon.contextSidebarTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconPanelRight}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.contextSidebar}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ToggleSceneNotesCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding IsSceneNotesVisible}"
                                            ToolTip.Tip="{loc:Loc ribbon.sceneNotesTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconPencil}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.sceneNotes}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.panels}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Export Group -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ShowExportCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Export}"
                                            ToolTip.Tip="{loc:Loc ribbon.exportTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconUpload}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.export}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.exportGroup}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Image Gallery Group -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ShowImageGalleryCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=ImageGallery}"
                                            ToolTip.Tip="{loc:Loc ribbon.galleryTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconImage}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.gallery}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.galleryGroup}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Git Group -->
                        <Border Classes="ribbonGroup"
                                IsVisible="{Binding IsInGitRepo}">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ShowGitCommand}"
                                            Classes="ribbonToggleLarge"
                                            Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Git}"
                                            ToolTip.Tip="{loc:Loc ribbon.gitTooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconGitBranch}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc ribbon.git}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc ribbon.gitGroup}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Dynamic extension ribbon groups for the View tab -->
                        <ItemsControl ItemsSource="{Binding ExtensionViewRibbonGroups}"
                                      x:DataType="vm:MainWindowViewModel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="0" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ExtensionRibbonGroup">
                                    <Border Classes="ribbonGroup">
                                        <Grid RowDefinitions="*,Auto">
                                            <ItemsControl Grid.Row="0" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="sdk:RibbonItem">
                                                        <Button Classes="ribbonToggleLarge"
                                                                ToolTip.Tip="{Binding Tooltip}"
                                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExecuteExtensionRibbonItemCommand}"
                                                                CommandParameter="{Binding}">
                                                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                                                <Viewbox Classes="ribbonIcon">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Classes="ribbonIcon" Data="{Binding IconPath}" />
                                                                    </Canvas>
                                                                </Viewbox>
                                                                <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Grid.Row="1" Text="{Binding GroupName}" Classes="ribbonGroupLabel" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══ Extensions Tab Content ═══ -->
                <Border Classes="ribbonContent"
                        IsVisible="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Extensions}">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <!-- Manage Group -->
                        <Border Classes="ribbonGroup">
                            <Grid RowDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Command="{Binding ToggleExtensionsCommand}"
                                            Classes="ribbonButtonLarge"
                                            ToolTip.Tip="{loc:Loc extensions.tooltip}">
                                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                                            <Viewbox Classes="ribbonIcon"><Canvas Width="24" Height="24"><Path Classes="ribbonIcon" Data="{StaticResource IconPlug}"/></Canvas></Viewbox>
                                            <TextBlock Text="{loc:Loc extensions.manage}" FontSize="10"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{loc:Loc extensions.title}" Classes="ribbonGroupLabel" />
                            </Grid>
                        </Border>

                        <!-- Dynamic extension ribbon groups -->
                        <ItemsControl ItemsSource="{Binding ExtensionRibbonGroups}"
                                      x:DataType="vm:MainWindowViewModel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="0" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ExtensionRibbonGroup">
                                    <Border Classes="ribbonGroup">
                                        <Grid RowDefinitions="*,Auto">
                                            <ItemsControl Grid.Row="0" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="sdk:RibbonItem">
                                                        <Button Classes="ribbonButtonLarge"
                                                                ToolTip.Tip="{Binding Tooltip}"
                                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExecuteExtensionRibbonItemCommand}"
                                                                CommandParameter="{Binding}">
                                                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                                                <Panel>
                                                                    <Viewbox Classes="ribbonIcon"
                                                                             IsVisible="{Binding IconPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                                        <Canvas Width="24" Height="24">
                                                                            <Path Classes="ribbonIcon"
                                                                                  Data="{Binding IconPath, Converter={x:Static conv:StringToGeometryConverter.Instance}}" />
                                                                        </Canvas>
                                                                    </Viewbox>
                                                                    <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center"
                                                                               IsVisible="{Binding IconPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                                </Panel>
                                                                <TextBlock Text="{Binding Label}" FontSize="10"
                                                                           HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Grid.Row="1" Text="{Binding GroupName}" Classes="ribbonGroupLabel" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,1,0,0"
                Padding="10,4"
                IsVisible="{Binding IsProjectLoaded}">
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Editor.WordCount, StringFormat='{}{0:N0} words'}"
                               Classes="statusMetric"
                               Foreground="{DynamicResource NormalText}"
                               IsVisible="{Binding Editor.IsDocumentOpen}" />
                    <TextBlock Text="{Binding Editor.CharacterCount, StringFormat='{}{0:N0} chars'}"
                               Classes="statusMetric"
                               IsVisible="{Binding Editor.IsDocumentOpen}" />
                    <TextBlock Text="{Binding Editor.CharacterCountWithoutSpaces, StringFormat='{}{0:N0} (no spaces)'}"
                               Classes="statusMetricDim"
                               IsVisible="{Binding Editor.IsDocumentOpen}" />
                    <TextBlock Text="{Binding Editor.ReadingTimeDisplay}"
                               Classes="statusMetric"
                               IsVisible="{Binding Editor.IsDocumentOpen}" />
                    <Border Classes="statusScoreBadge"
                            Background="{Binding Editor.ReadabilityColor}"
                            IsVisible="{Binding Editor.HasReadability}">
                        <TextBlock Text="{Binding Editor.ReadabilityDisplay}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="White" />
                    </Border>
                    <TextBlock Text="{Binding Editor.ReadabilityLevelLabel}"
                               Classes="statusMetric"
                               IsVisible="{Binding Editor.HasReadability}" />
                    <TextBlock Text="{loc:Loc statusBar.openSceneHint}"
                               Classes="statusMetricDim"
                               IsVisible="{Binding Editor.IsDocumentOpen, Converter={x:Static BoolConverters.Not}}" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="ProjectOverviewButton"
                        Classes="statusOverviewButton"
                        Command="{Binding ToggleProjectOverviewCommand}"
                        IsEnabled="{Binding HasProjectOverview}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProjectTotalWordsDisplay}"
                                   Classes="statusMetric"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock Text="{Binding ProjectChapterCount, StringFormat='{}{0} ch'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectSceneCount, StringFormat='{}{0} sc'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectCharacterCount, StringFormat='{}{0} chars'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectLocationCount, StringFormat='{}{0} loc'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectReadingTimeDisplay}"
                                   Classes="statusMetricDim" />
                        <TextBlock Text="{Binding AverageChapterWordsDisplay, StringFormat='~ {0}/ch'}"
                                   Classes="statusMetricDim" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTip.Tip="{Binding GoalTooltip}">
                    <!-- Extension status bar items -->
                    <ItemsControl ItemsSource="{Binding ExtensionStatusBarItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExtensionStatusBarItemVM">
                                <Button Classes="statusOverviewButton"
                                        Padding="4,2"
                                        ToolTip.Tip="{Binding TooltipText}"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExecuteExtensionStatusBarItemCommand}"
                                        CommandParameter="{Binding Source}">
                                    <TextBlock Text="{Binding DisplayText}"
                                               Classes="statusMetric"
                                               Foreground="{DynamicResource NormalText}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Git status -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                IsVisible="{Binding IsInGitRepo}"
                                Margin="0,0,8,0">
                        <Button Classes="statusOverviewButton"
                                Command="{Binding ShowGitCommand}"
                                Padding="4,2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding GitBranchDisplay}"
                                           Classes="statusMetric"
                                           Foreground="{DynamicResource NormalText}" />
                                <TextBlock Text="{Binding GitChangedCount, StringFormat='{}{0} ✎'}"
                                           Classes="statusMetricDim" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding DailyGoalLabel}"
                               Classes="statusMetric"
                               Foreground="{DynamicResource NormalText}" />
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Width="72"
                                 Height="4"
                                 Value="{Binding DailyGoalPercent}" />
                    <TextBlock Text="{Binding ProjectGoalLabel}"
                               Classes="statusMetric"
                               Foreground="{DynamicResource NormalText}" />
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Width="72"
                                 Height="4"
                                 Value="{Binding ProjectGoalPercent}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Panel>
            <!-- Welcome Screen (when no project loaded) -->
            <views:WelcomeView x:Name="WelcomeViewControl"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsProjectLoaded, Converter={x:Static BoolConverters.Not}}" />

            <!-- Project Content (when project loaded) -->
            <Grid x:Name="ProjectContentGrid" IsVisible="{Binding IsProjectLoaded}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="180" MaxWidth="500" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar: stacked Explorer + Entity Panel -->
                          <Grid Grid.Column="0"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsExplorerVisible}">
                    <!-- Sidebar mode tabs -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,Auto"
                          Background="{DynamicResource ExplorerBackground}">
                        <Button Grid.Column="0" Content="{loc:Loc sidebar.chapters}"
                                x:Name="SidebarChaptersTab"
                                Click="OnSidebarTabClick" Tag="Chapters"
                                Classes="explorerTab" Padding="10,6" FontSize="11"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="{loc:Loc sidebar.entities}"
                                x:Name="SidebarEntitiesTab"
                                Click="OnSidebarTabClick" Tag="Entities"
                                Classes="explorerTab" Padding="10,6" FontSize="11"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <!-- Extension sidebar tabs -->
                        <ItemsControl Grid.Column="2" ItemsSource="{Binding ExtensionSidebarTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ExtensionSidebarTabVM">
                                    <Button Content="{Binding Label}"
                                            Click="OnExtensionSidebarTabClick"
                                            Tag="{Binding Id}"
                                            Classes="explorerTab" Padding="10,6" FontSize="11"
                                            ToolTip.Tip="{Binding Tooltip}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                                        <Panel Grid.Row="1">
                                                <!-- Chapter Explorer -->
                                                <views:ExplorerView DataContext="{Binding Explorer}"
                                                                                        x:Name="ExplorerPanel"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        VerticalAlignment="Stretch" />

                                                <!-- Entity Panel -->
                                                <views:EntityPanelView DataContext="{Binding EntityPanel}"
                                                                                             x:Name="EntityPanelControl"
                                                                                             HorizontalAlignment="Stretch"
                                                                                             VerticalAlignment="Stretch"
                                                                                             IsVisible="False" />

                                                <!-- Extension sidebar panel host -->
                                                <ContentControl x:Name="ExtensionSidebarHost"
                                                                IsVisible="False"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch" />
                                        </Panel>
                                </Grid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="Transparent"
                              IsVisible="{Binding IsExplorerVisible}" />

                <!-- Main Content Area -->
                <Grid Grid.Column="2">
                    <Grid Grid.Column="0"
                      RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="editorTabStrip"
                            IsVisible="{Binding HasOpenEditors}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="0">
                            <Border Classes="editorTabHost"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Scene}"
                                    IsVisible="{Binding Editor.IsDocumentOpen}"
                                    Tag="Scene"
                                    PointerPressed="OnEditorTabPointerPressed">
                                <Grid ColumnDefinitions="*,Auto"
                                      MinWidth="180">
                                    <Button Grid.Column="0"
                                            Classes="editorTabSurface"
                                            Command="{Binding SetActiveContentViewCommand}"
                                            CommandParameter="Scene"
                                            ToolTip.Tip="{Binding Editor.DocumentTitle}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Border Classes="editorTabBadge">
                                                <TextBlock Text="SCN"
                                                           Classes="editorTabBadgeText" />
                                            </Border>
                                            <TextBlock Text="{Binding Editor.SceneTabTitle}"
                                                       Classes="editorTabText" />
                                            <Border Classes="editorTabDirtyDot"
                                                    IsVisible="{Binding Editor.IsDirty}" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Classes="editorTabCloseButton"
                                            Command="{Binding CloseSceneTabCommand}"
                                            ToolTip.Tip="Close scene tab">
                                        <Path Classes="editorTabCloseGlyph" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Classes="editorTabHost"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Entity}"
                                    IsVisible="{Binding EntityEditor.IsOpen}"
                                    Tag="Entity"
                                    PointerPressed="OnEditorTabPointerPressed">
                                <Grid ColumnDefinitions="*,Auto"
                                      MinWidth="180">
                                    <Button Grid.Column="0"
                                            Classes="editorTabSurface"
                                            Command="{Binding SetActiveContentViewCommand}"
                                            CommandParameter="Entity"
                                            ToolTip.Tip="{Binding EntityEditor.Title}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Border Classes="editorTabBadge">
                                                <TextBlock Text="ENT"
                                                           Classes="editorTabBadgeText" />
                                            </Border>
                                            <TextBlock Text="{Binding EntityEditor.Title}"
                                                       Classes="editorTabText" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Classes="editorTabCloseButton"
                                            Command="{Binding CloseEntityTabCommand}"
                                            ToolTip.Tip="Close entity tab">
                                        <Path Classes="editorTabCloseGlyph" />
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid x:Name="SceneContentPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="320" MinWidth="280" MaxWidth="600" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="0" MinWidth="0" MaxWidth="0" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0"
                                  RowDefinitions="*,Auto,Auto">
                                <views:EditorView Grid.Row="0"
                                                  DataContext="{Binding Editor}"
                                                  x:Name="EditorPanel" />

                                <GridSplitter Grid.Row="1"
                                              ResizeDirection="Rows"
                                              Height="4"
                                              Background="Transparent"
                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSceneNotesVisible}" />

                                <views:SceneNotesView Grid.Row="2"
                                                      DataContext="{Binding SceneNotes}"
                                                      Height="180"
                                                      IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSceneNotesVisible}" />
                            </Grid>

                            <GridSplitter Grid.Column="1"
                                          ResizeDirection="Columns"
                                          Background="Transparent"
                                          IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsContextSidebarVisible}" />

                            <views:ContextSidebarView Grid.Column="2"
                                                      DataContext="{Binding ContextSidebar}"
                                                      x:Name="ContextSidebarPanel"
                                                      IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsContextSidebarVisible}" />

                            <!-- Extension right sidebar splitter -->
                            <GridSplitter Grid.Column="3"
                                          ResizeDirection="Columns"
                                          Background="Transparent"
                                          IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionRightSidebarVisible}" />

                            <!-- Extension right sidebar host -->
                            <ContentControl Grid.Column="4"
                                            x:Name="ExtensionRightSidebarHost"
                                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionRightSidebarVisible}" />
                        </Grid>

                        <!-- Entity Editor -->
                        <views:EntityEditorView DataContext="{Binding EntityEditor}"
                                                 x:Name="EntityEditorPanel"
                                                 IsVisible="False" />

                        <!-- Dashboard -->
                        <views:DashboardView DataContext="{Binding Dashboard}"
                                              x:Name="DashboardPanel"
                                              IsVisible="False" />

                        <!-- Timeline -->
                        <views:TimelineView DataContext="{Binding Timeline}"
                                             x:Name="TimelinePanel"
                                             IsVisible="False" />

                        <!-- Export -->
                        <views:ExportView DataContext="{Binding Export}"
                                           x:Name="ExportPanel"
                                           IsVisible="False" />

                        <!-- Image Gallery -->
                        <views:ImageGalleryView DataContext="{Binding ImageGallery}"
                                                 x:Name="ImageGalleryPanel"
                                                 IsVisible="False" />

                        <!-- Git -->
                        <views:GitView DataContext="{Binding Git}"
                                        x:Name="GitPanel"
                                        IsVisible="False" />

                        <!-- Codex Hub -->
                        <views:CodexHubView DataContext="{Binding CodexHub}"
                                             x:Name="CodexHubPanel"
                                             IsVisible="False" />

                        <!-- Manuscript -->
                        <views:ManuscriptView DataContext="{Binding Manuscript}"
                                               x:Name="ManuscriptPanel"
                                               IsVisible="False" />

                        <!-- Extension content views -->
                        <ContentControl x:Name="ExtensionContentHost" IsVisible="False" />
                    </Grid>
                </Grid>
                </Grid>
            </Grid>

            <Border IsVisible="{Binding IsProjectOverviewOpen}"
                    x:Name="ProjectOverviewOverlay"
                    Focusable="True"
                    Background="Transparent"
                    PointerPressed="OnProjectOverviewOverlayPressed">
                <Border CornerRadius="8"
                        Width="460"
                        MinWidth="300"
                        MaxWidth="460"
                        MaxHeight="360"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,26"
                        Background="{DynamicResource CardBackground}">
                    <Border Background="Transparent"
                            Padding="10,12"
                            PointerPressed="OnProjectOverviewPopupPressed">
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="{loc:Loc project.renameProject}"
                                    Command="{Binding RenameProjectCommand}"
                                    Padding="8,2"
                                    FontSize="11"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ProjectName}"
                                       Classes="statusPopupTitle"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>

                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8"
                              Margin="0,0,0,2">
                            <TextBlock Grid.Column="0"
                                       Text="{loc:Loc overview.chapterColumn}"
                                       Classes="statusPopupHeaderCell" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Loc overview.wordsColumn}"
                                       Classes="statusPopupHeaderCell" />
                            <TextBlock Grid.Column="2"
                                       Text="{loc:Loc overview.readabilityColumn}"
                                       Classes="statusPopupHeaderCell" />
                        </Grid>

                        <ScrollViewer MaxHeight="300"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc overview.noChapters}"
                                           Classes="statusPopupBody"
                                           IsVisible="{Binding HasProjectOverview, Converter={x:Static BoolConverters.Not}}" />

                                <ItemsControl ItemsSource="{Binding ProjectOverviewChapters}"
                                              IsVisible="{Binding HasProjectOverview}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:StatusBarChapterOverviewItem">
                                            <StackPanel>
                                                <Border Classes="statusPopupRow">
                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                          ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   Classes="statusPopupName" />

                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding WordCountDisplay}"
                                                                       Classes="statusPopupWords" />
                                                            <Border Classes="statusPopupMiniBar">
                                                                <Border Classes="statusPopupMiniBarFill"
                                                                        Width="{Binding BarWidth}" />
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    Spacing="0"
                                                                    VerticalAlignment="Center">
                                                            <Border Classes="statusPopupReadabilityBadge"
                                                                    Background="{Binding ReadabilityColor}"
                                                                    IsVisible="{Binding HasReadability}">
                                                                <TextBlock Text="{Binding ReadabilityDisplay}"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="White" />
                                                            </Border>
                                                            <TextBlock Text="{Binding ReadabilityLevelLabel}"
                                                                       Classes="statusPopupLevel"
                                                                       IsVisible="{Binding HasReadability}" />
                                                            <TextBlock Text="–"
                                                                       Classes="statusPopupNA"
                                                                       IsVisible="{Binding HasReadability, Converter={x:Static BoolConverters.Not}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding Scenes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:StatusBarSceneOverviewItem">
                                                            <Border Classes="statusPopupRow">
                                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                                      ColumnSpacing="8">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Name}"
                                                                               Margin="16,0,0,0"
                                                                               Classes="statusPopupSceneName" />

                                                                    <StackPanel Grid.Column="1"
                                                                                Orientation="Horizontal"
                                                                                Spacing="0"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding WordCountDisplay}"
                                                                                   Classes="statusPopupSceneWords" />
                                                                        <Border Classes="statusPopupMiniBar">
                                                                            <Border Classes="statusPopupMiniBarFill"
                                                                                    Width="{Binding BarWidth}" />
                                                                        </Border>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="2"
                                                                               Text=""
                                                                               Classes="statusPopupNA" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                    </Border>
                </Border>
            </Border>

            <!-- Book Picker Overlay -->
            <Border IsVisible="{Binding IsBookPickerOpen}"
                    x:Name="BookPickerOverlay"
                    Focusable="True"
                    Background="#80000000"
                    PointerPressed="OnBookPickerOverlayPressed">
                <Border CornerRadius="8"
                        MinWidth="420"
                        MaxWidth="780"
                        MaxHeight="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource CardBackground}"
                        PointerPressed="OnBookPickerPopupPressed">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{loc:Loc book.pickerTitle}"
                                   Classes="statusPopupTitle"
                                   Margin="0,0,0,12" />

                        <Button DockPanel.Dock="Bottom"
                                Content="{loc:Loc book.addBook}"
                                Command="{Binding AddBookCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0" />

                        <TextBlock Text="{loc:Loc book.noBooks}"
                                   Classes="statusPopupBody"
                                   IsVisible="{Binding !BookCards.Count}" />

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding BookCards.Count}">
                            <ItemsControl ItemsSource="{Binding BookCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BookCard">
                                        <Button Classes="linkButton"
                                                Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SelectBookFromPickerCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Margin="0,0,12,12">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{loc:Loc book.renameBook}" Click="OnBookCardRenameClick" />
                                                    <MenuItem Header="{loc:Loc book.deleteBook}" Click="OnBookCardDeleteClick" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Border Background="{DynamicResource CardBackground}"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    BorderThickness="1"
                                                    Classes.active="{Binding IsActive}"
                                                    CornerRadius="8"
                                                    Width="160"
                                                    ClipToBounds="True">
                                                <Border.Styles>
                                                    <Style Selector="Border.active">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </Style>
                                                </Border.Styles>
                                                <StackPanel>
                                                    <Panel Height="200">
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapInterpolationMode="HighQuality"
                                                               IsVisible="{Binding HasCoverImage}" />
                                                        <Border Background="{DynamicResource CardBackground}"
                                                                IsVisible="{Binding !HasCoverImage}">
                                                            <Viewbox Width="40" Height="40"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                                                          Stroke="{DynamicResource SubtleText}"
                                                                          Data="{StaticResource IconBookOpen}"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                    </Panel>
                                                    <StackPanel Spacing="2" Margin="10,8,10,10">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource NormalText}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="1" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Border>

            <!-- Settings Overlay -->
            <views:SettingsView x:Name="SettingsViewControl"
                                 Focusable="True"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSettingsOpen}" />

            <!-- Extensions Overlay -->
            <views:ExtensionsView Focusable="True"
                                   DataContext="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Extensions}"
                                   IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionsOpen}" />

        </Panel>
    </DockPanel>

    <!-- Dialog Host Overlay — covers entire window for in-window modal dialogs -->
    <Border x:Name="DialogOverlay"
            Background="#80000000"
            IsVisible="False"
            Focusable="True"
            ZIndex="200">
        <Border CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource CardBackground}">
            <ContentPresenter x:Name="DialogHostPresenter" />
        </Border>
    </Border>

    <!-- Start Menu Overlay (File-style backstage) — covers entire window including ribbon -->
    <Border IsVisible="{Binding IsStartMenuOpen}"
            x:Name="StartMenuOverlay"
            Background="#80000000"
            Focusable="True"
            PointerPressed="OnStartMenuOverlayPressed">
        <Border x:Name="StartMenuPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Width="280"
                Background="{DynamicResource ExplorerBackground}">
            <Border Background="Transparent"
                    PointerPressed="OnStartMenuPanelPressed">
                <DockPanel Margin="0,8">
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding AppVersion}"
                               FontSize="11"
                               Opacity="0.45"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,8" />
                    <StackPanel>
                        <!-- Open Project -->
                        <Button Classes="startMenuItem"
                                Command="{Binding OpenProjectFromMenuCommand}"
                                ToolTip.Tip="{loc:Loc startMenu.openProjectTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconFolderOpen}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.openProject}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Recent Projects submenu -->
                        <Button Classes="startMenuItem">
                            <Button.Flyout>
                                <MenuFlyout Placement="RightEdgeAlignedTop">
                                    <ItemsControl ItemsSource="{Binding SettingsService.Settings.RecentProjects}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:RecentProject">
                                                <MenuItem Header="{Binding Name}"
                                                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenRecentProjectFromMenuCommand}"
                                                          CommandParameter="{Binding}"
                                                          ToolTip.Tip="{Binding Path}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </MenuFlyout>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconFolder}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.recentProjects}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="12,6" />

                        <!-- Settings -->
                        <Button Classes="startMenuItem"
                                Command="{Binding ToggleSettingsCommand}"
                                ToolTip.Tip="{loc:Loc ribbon.settingsTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconSettings}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc ribbon.settingsLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="startMenuItem"
                                Command="{Binding ToggleExtensionsCommand}"
                                ToolTip.Tip="{loc:Loc extensions.tooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconPlug}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc extensions.title}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="12,6" />

                        <!-- Close Project -->
                        <Button Classes="startMenuItem"
                                Command="{Binding CloseProjectCommand}"
                                ToolTip.Tip="{loc:Loc startMenu.closeProjectTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconBookOpen}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.closeProject}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Border>
    </Border>
    <!-- Extension notification toast -->
    <Border IsVisible="{Binding ExtensionNotification, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,52"
            Padding="16,10"
            CornerRadius="8"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource PanelBorder}"
            BorderThickness="1"
            BoxShadow="0 4 12 0 #40000000">
        <TextBlock Text="{Binding ExtensionNotification}"
                   Foreground="{DynamicResource NormalText}"
                   FontSize="13" />
    </Border>
    </Panel>
</Window>
