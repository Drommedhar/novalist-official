<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.InverseRelationshipDialog"
        Width="460"
        Focusable="True">
    <Border Background="Transparent"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,16,0,0">
                <Button x:Name="CancelButton"
                        Content="{loc:Loc dialog.cancel}"
                        Padding="16,8"
                        Click="OnCancel" />
                <Button x:Name="OkButton"
                        Content="{loc:Loc dialog.update}"
                        Classes="primary"
                        Click="OnOk"
                        IsDefault="True" />
            </StackPanel>
            <StackPanel Spacing="10">
                <TextBlock x:Name="DescriptionText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource NormalText}"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="QuestionText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource DimText}" />
                <TextBox x:Name="InputBox"
                         Watermark="{loc:Loc dialog.inverseRelWatermark}"
                         MaxLength="100" />
                <ItemsControl x:Name="SuggestionsList"
                              IsVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Padding="10,4"
                                    Margin="0,0,8,8"
                                    Click="OnSuggestionClicked" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
