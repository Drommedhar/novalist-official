<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.UpdateDialog"
        Width="480"
        Focusable="True">
    <Border Background="Transparent"
            Padding="24">
        <DockPanel>
            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource SpacingMedium}"
                        Margin="0,16,0,0">
                <Button x:Name="SkipButton"
                        Content="{loc:Loc update.skip}"
                        Padding="16,8"
                        Click="OnSkip" />
                <Button x:Name="DownloadButton"
                        Content="{loc:Loc update.downloadInstall}"
                        Classes="primary"
                        Padding="16,8"
                        Click="OnDownload"
                        IsDefault="True" />
            </StackPanel>

            <StackPanel Spacing="{StaticResource SpacingLarge}">
                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NormalText}" />

                <!-- Version info -->
                <TextBlock x:Name="VersionText"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           Foreground="{DynamicResource SubtleText}"
                           TextWrapping="Wrap" />

                <!-- Release notes -->
                <ScrollViewer MaxHeight="200"
                              x:Name="ReleaseNotesScroll"
                              IsVisible="False">
                    <TextBlock x:Name="ReleaseNotesText"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource SubtleText}"
                               TextWrapping="Wrap" />
                </ScrollViewer>

                <!-- Progress bar (hidden until downloading) -->
                <StackPanel x:Name="ProgressPanel"
                            IsVisible="False"
                            Spacing="{StaticResource SpacingTighter}">
                    <ProgressBar x:Name="DownloadProgress"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6" />
                    <TextBlock x:Name="ProgressText"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               Foreground="{DynamicResource SubtleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Error message -->
                <TextBlock x:Name="ErrorText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           IsVisible="False" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
