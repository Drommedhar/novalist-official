<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.ConfirmDialog"
        Width="420"
        Focusable="True">
    <Border Background="Transparent"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Classes="dialogButtonRow">
                <Button x:Name="CancelButton"
                        Content="{loc:Loc dialog.cancel}"
                        IsCancel="True"
                        Click="OnCancel" />
                <Button x:Name="ConfirmButton"
                        Classes="danger"
                        Content="{loc:Loc dialog.delete}"
                        Click="OnConfirm"
                        IsDefault="True" />
            </StackPanel>
            <TextBlock x:Name="MessageText"
                       FontSize="{StaticResource FontSizeTitleSmall}"
                       Foreground="{DynamicResource NormalText}"
                       TextWrapping="Wrap" />
        </DockPanel>
    </Border>
</UserControl>
