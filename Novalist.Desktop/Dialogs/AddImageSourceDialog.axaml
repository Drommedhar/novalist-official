<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.AddImageSourceDialog"
        Width="420"
        Focusable="True">
    <Border Background="Transparent"
            Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,16,0,0">
                <Button x:Name="CancelButton"
                        Content="{loc:Loc dialog.cancel}"
                        Padding="16,8"
                        Click="OnCancel" />
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="{loc:Loc dialog.addImageQuestion}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NormalText}" />
                <TextBlock Text="{loc:Loc dialog.addImageDescription}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource DimText}" />

                <Button x:Name="LibraryButton"
                        Content="{loc:Loc dialog.selectFromLibrary}"
                        Classes="primary"
                        HorizontalAlignment="Stretch"
                        Padding="14,10"
                        Click="OnSelectFromLibrary" />

                <Button x:Name="ImportButton"
                        Content="{loc:Loc dialog.importFile}"
                        HorizontalAlignment="Stretch"
                        Padding="14,10"
                        Click="OnImportFile" />

                <Button x:Name="ClipboardButton"
                        Content="{loc:Loc dialog.fromClipboard}"
                        HorizontalAlignment="Stretch"
                        Padding="14,10"
                        Click="OnFromClipboard" />

                <Button x:Name="UrlButton"
                        Content="{loc:Loc dialog.fromUrl}"
                        HorizontalAlignment="Stretch"
                        Padding="14,10"
                        Click="OnFromUrl" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>