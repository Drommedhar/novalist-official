<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.ManuscriptView"
             x:DataType="vm:ManuscriptViewModel">

    <Border Background="{DynamicResource EditorBackground}">
        <DockPanel>
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="16,10"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource ExplorerBackground}">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Left: Title + Stats -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource SpacingXL}" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc manuscript.title}"
                                   FontSize="{DynamicResource FontSizeTitleSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock x:Name="StatsText"
                                   Classes="nlvCaptionLabel"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: View mode + Filter controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                            <Button Content="{loc:Loc manuscript.viewModeManuscript}"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="Manuscript"
                                    Classes="ribbonToggleLarge"
                                    Classes.active="{Binding IsManuscriptMode}"
                                    Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />
                            <Button Content="{loc:Loc manuscript.viewModeCorkboard}"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="Corkboard"
                                    Classes="ribbonToggleLarge"
                                    Classes.active="{Binding IsCorkboardMode}"
                                    Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />
                            <Button Content="{loc:Loc manuscript.viewModeOutliner}"
                                    Command="{Binding SetViewModeCommand}"
                                    CommandParameter="Outliner"
                                    Classes="ribbonToggleLarge"
                                    Classes.active="{Binding IsOutlinerMode}"
                                    Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                        <Button Content="{loc:Loc manuscript.filterAll}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="All"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=All}"
                                Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />

                        <Button Content="{loc:Loc manuscript.filterOutline}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Outline"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Outline}"
                                Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />

                        <Button Content="{loc:Loc manuscript.filterDraft}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="FirstDraft"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=FirstDraft}"
                                Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />

                        <Button Content="{loc:Loc manuscript.filterFinal}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Final"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Final}"
                                Padding="10,5" FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Empty state -->
            <Border IsVisible="{Binding !HasContent}"
                    Padding="40">
                <TextBlock Text="{loc:Loc manuscript.empty}"
                           FontSize="{StaticResource FontSizeTitleSmall}"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <Grid IsVisible="{Binding HasContent}">
                <!-- WebView host (composite Manuscript mode) -->
                <Grid x:Name="ManuscriptHost"
                      IsVisible="{Binding IsManuscriptMode}" />

                <!-- Corkboard mode: chapters as headers, scenes as cards -->
                <ScrollViewer IsVisible="{Binding IsCorkboardMode}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Sections}" Margin="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ManuscriptSection">
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="{Binding ChapterTitle}"
                                               FontSize="{StaticResource FontSizeTitleSmall}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"
                                               Foreground="{DynamicResource NormalText}" />
                                    <ItemsControl ItemsSource="{Binding Scenes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ManuscriptSceneItem">
                                                <Border Width="220" Height="160"
                                                        Margin="0,0,12,12"
                                                        Background="{DynamicResource ExplorerBackground}"
                                                        BorderBrush="{DynamicResource CardBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource RadiusSmall}"
                                                        Padding="10">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Top"
                                                                   Text="{Binding Title}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{StaticResource FontSizeBody}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource NormalText}" />
                                                        <TextBlock DockPanel.Dock="Bottom"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{DynamicResource SubtleText}">
                                                            <Run Text="{Binding WordCount}" />
                                                            <Run Text=" " />
                                                            <Run Text="{loc:Loc snapshots.words}" />
                                                        </TextBlock>
                                                        <TextBox Text="{Binding Synopsis, Mode=TwoWay}"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 Watermark="{loc:Loc sceneNotes.synopsisPlaceholder}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0,4,0,0"
                                                                 FontSize="{StaticResource FontSizeBodySmall}"
                                                                 Foreground="{DynamicResource NormalText}" />
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Outliner mode: table of scenes -->
                <ScrollViewer IsVisible="{Binding IsOutlinerMode}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AllScenes}" Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ManuscriptSceneItem">
                                <Grid ColumnDefinitions="180,160,*,80,80"
                                      Margin="0,0,0,4"
                                      Background="{DynamicResource ExplorerBackground}">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ChapterTitle}"
                                               Padding="6,4"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource SubtleText}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Padding="6,4"
                                               TextTrimming="CharacterEllipsis"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource NormalText}" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Synopsis, Mode=TwoWay}"
                                             Padding="6,4"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Watermark="{loc:Loc sceneNotes.synopsisPlaceholder}" />
                                    <TextBox Grid.Column="3"
                                             Text="{Binding Pov, Mode=TwoWay}"
                                             Padding="6,4"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Watermark="{loc:Loc common.povWatermark}" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding WordCount}"
                                               Padding="6,4"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource SubtleText}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>