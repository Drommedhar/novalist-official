<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.ManuscriptView"
             x:DataType="vm:ManuscriptViewModel">

    <Border Background="{DynamicResource EditorBackground}">
        <DockPanel>
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="16,10"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource ExplorerBackground}">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Left: Title + Stats -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc manuscript.title}"
                                   FontSize="{DynamicResource FontSizeTitleSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock x:Name="StatsText"
                                   Classes="nlvCaptionLabel"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: Filter controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Button Content="{loc:Loc manuscript.filterAll}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="All"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=All}"
                                Padding="10,5" FontSize="11" />

                        <Button Content="{loc:Loc manuscript.filterOutline}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Outline"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Outline}"
                                Padding="10,5" FontSize="11" />

                        <Button Content="{loc:Loc manuscript.filterDraft}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="FirstDraft"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=FirstDraft}"
                                Padding="10,5" FontSize="11" />

                        <Button Content="{loc:Loc manuscript.filterFinal}"
                                Command="{Binding SetFilterCommand}"
                                CommandParameter="Final"
                                Classes="ribbonToggleLarge"
                                Classes.active="{Binding FilterStatus, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Final}"
                                Padding="10,5" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Empty state -->
            <Border IsVisible="{Binding !HasContent}"
                    Padding="40">
                <TextBlock Text="{loc:Loc manuscript.empty}"
                           FontSize="14"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- WebView host -->
            <Grid x:Name="ManuscriptHost"
                  IsVisible="{Binding HasContent}" />
        </DockPanel>
    </Border>
</UserControl>