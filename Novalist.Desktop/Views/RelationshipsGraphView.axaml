<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             x:Class="Novalist.Desktop.Views.RelationshipsGraphView"
             x:DataType="vm:RelationshipsGraphViewModel">
    <Border Background="{DynamicResource EditorBackground}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Padding="16,10"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource ExplorerBackground}">
                <TextBlock Text="{loc:Loc relationships.title}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource NormalText}" />
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Canvas Width="960" Height="720" Background="{DynamicResource EditorBackground}">
                    <ItemsControl ItemsSource="{Binding Edges}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationshipEdge">
                                <Canvas>
                                    <Line StartPoint="{Binding StartPoint}"
                                          EndPoint="{Binding EndPoint}"
                                          Stroke="{DynamicResource SubtleText}"
                                          StrokeThickness="1"
                                          Opacity="0.5" />
                                    <TextBlock Canvas.Left="{Binding LabelX}"
                                               Canvas.Top="{Binding LabelY}"
                                               Text="{Binding Label}"
                                               FontSize="10"
                                               Opacity="0.65"
                                               Foreground="{DynamicResource SubtleText}" />
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationshipNode">
                                <Border Canvas.Left="{Binding X}"
                                        Canvas.Top="{Binding Y}"
                                        Width="80"
                                        Padding="6,4"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <TextBlock Text="{Binding Name}"
                                               TextAlignment="Center"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource NormalText}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
