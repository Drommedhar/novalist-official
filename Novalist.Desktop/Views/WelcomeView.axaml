<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Novalist.Desktop.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">

    <Border Background="{DynamicResource WelcomeBackground}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Width="820"
                            MaxWidth="820"
                            Margin="32,72,32,48"
                            Spacing="36">

                    <!-- Hero -->
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                            <Viewbox Classes="ribbonIcon" Width="40" Height="40">
                                <Canvas Width="24" Height="24">
                                    <Path Classes="ribbonIcon" Data="{StaticResource IconBookOpen}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{loc:Loc app.title}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource NormalText}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{loc:Loc app.subtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SubtleText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Primary action row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Command="{Binding OpenProjectCommand}"
                                Classes="welcomeAction"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="Auto,*">
                                <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                              Stroke="{DynamicResource NormalText}"
                                              Data="{StaticResource IconFolderOpen}"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="{loc:Loc welcome.browseFolder}"
                                           VerticalAlignment="Center" FontSize="13"
                                           TextWrapping="Wrap" TextAlignment="Left" />
                            </Grid>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{Binding ImportPluginProjectCommand}"
                                Classes="welcomeAction"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="Auto,*">
                                <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Canvas Width="24" Height="24">
                                        <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                              Stroke="{DynamicResource NormalText}"
                                              Data="{StaticResource IconUpload}"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="{loc:Loc welcome.importPlugin}"
                                           VerticalAlignment="Center" FontSize="13"
                                           TextWrapping="Wrap" TextAlignment="Left" />
                            </Grid>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding ToggleCreateFormCommand}"
                                Classes="welcomeAction primary"
                                HorizontalAlignment="Stretch">
                            <TextBlock Text="{loc:Loc welcome.createTitle}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </Grid>

                    <!-- Inline create form (collapsible) -->
                    <Border IsVisible="{Binding IsCreateFormOpen}"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc welcome.projectName}" FontSize="11" Foreground="{DynamicResource DimText}" />
                                <TextBox Text="{Binding NewProjectName}"
                                         Watermark="{loc:Loc welcome.projectNamePlaceholder}"
                                         MaxLength="100"
                                         FontSize="13" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc welcome.bookName}" FontSize="11" Foreground="{DynamicResource DimText}" />
                                <TextBox Text="{Binding NewBookName}"
                                         Watermark="{loc:Loc welcome.bookNamePlaceholder}"
                                         MaxLength="100"
                                         FontSize="13" />
                                <TextBlock Text="{loc:Loc welcome.bookNameHint}" FontSize="10" Foreground="{DynamicResource SubtleText}" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc welcome.location}" FontSize="11" Foreground="{DynamicResource DimText}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding NewProjectLocation}"
                                             Watermark="{loc:Loc welcome.locationPlaceholder}"
                                             IsReadOnly="True"
                                             FontSize="13" />
                                    <Button Grid.Column="1"
                                            Content="{loc:Loc welcome.browse}"
                                            Command="{Binding BrowseLocationCommand}"
                                            Margin="4,0,0,0"
                                            FontSize="12" />
                                </Grid>
                            </StackPanel>
                            <Button Content="{loc:Loc welcome.createProject}"
                                    Command="{Binding CreateProjectCommand}"
                                    Classes="primary"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Recent projects -->
                    <StackPanel Spacing="14">
                        <TextBlock Text="{loc:Loc welcome.recentProjects}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />

                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="8"
                                    IsVisible="{Binding !RecentProjects.Count}">
                            <Viewbox Width="40" Height="40" HorizontalAlignment="Center" Opacity="0.3">
                                <Canvas Width="24" Height="24">
                                    <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                          Stroke="{DynamicResource SubtleText}"
                                          Data="{StaticResource IconBookOpen}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="{loc:Loc welcome.noRecentProjects}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SubtleText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding RecentProjects}"
                                      IsVisible="{Binding RecentProjects.Count}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RecentProjectCard">
                                    <Button Classes="linkButton"
                                            Command="{Binding $parent[ItemsControl].((vm:WelcomeViewModel)DataContext).OpenRecentProjectCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="0"
                                            Margin="0,0,12,12">
                                        <Border Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource CardBorder}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Width="160"
                                                ClipToBounds="True">
                                            <StackPanel>
                                                <Panel Height="200">
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapInterpolationMode="HighQuality"
                                                           IsVisible="{Binding HasCoverImage}" />
                                                    <Border Background="{DynamicResource CardBackground}"
                                                            IsVisible="{Binding HasCoverImage, Converter={x:Static BoolConverters.Not}}">
                                                        <Viewbox Width="40" Height="40"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Canvas Width="24" Height="24">
                                                                <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                                                      Stroke="{DynamicResource SubtleText}"
                                                                      Data="{StaticResource IconBookOpen}"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                </Panel>
                                                <StackPanel Spacing="2" Margin="10,8,10,10">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource NormalText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1" />
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
