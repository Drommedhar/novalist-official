<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:models="using:Novalist.Core.Models"
             xmlns:conv="using:Novalist.Desktop.Converters"
             xmlns:loc="using:Novalist.Desktop.Localization"
             x:Class="Novalist.Desktop.Views.ResearchView"
             x:DataType="vm:ResearchViewModel">
    <Border Background="{DynamicResource EditorBackground}">
        <Grid ColumnDefinitions="280,*">
            <!-- Sidebar: list -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ExplorerBackground}"
                    BorderBrush="{DynamicResource ExplorerBorder}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="10,8"
                            BorderBrush="{DynamicResource ExplorerBorder}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="{loc:Loc research.title}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />
                    </Border>

                    <Border DockPanel.Dock="Top" Padding="6,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="{loc:Loc research.addNote}"
                                    Command="{Binding AddNoteCommand}"
                                    FontSize="11" Padding="8,4" />
                            <Button Content="{loc:Loc research.addLink}"
                                    Command="{Binding AddLinkCommand}"
                                    FontSize="11" Padding="8,4" />
                            <Button Content="{loc:Loc research.importFile}"
                                    Command="{Binding ImportFileCommand}"
                                    FontSize="11" Padding="8,4" />
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Padding="6,4,6,6">
                        <TextBox Text="{Binding SearchQuery, Mode=TwoWay}"
                                 Watermark="{loc:Loc research.search}"
                                 FontSize="11" />
                    </Border>

                    <ListBox ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:ResearchItem">
                                <StackPanel Spacing="2" Margin="2,2">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Type}" FontSize="10" Opacity="0.6" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Editor pane -->
            <DockPanel Grid.Column="1"
                       IsVisible="{Binding HasSelection}"
                       Margin="14,12">
                <StackPanel DockPanel.Dock="Top" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0"
                                 Text="{Binding SelectedItem.Title, Mode=TwoWay}"
                                 Watermark="{loc:Loc research.titleWatermark}"
                                 FontSize="14"
                                 FontWeight="SemiBold" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableTypes}"
                                  SelectedItem="{Binding SelectedItem.Type, Mode=TwoWay}"
                                  Width="120" />
                    </Grid>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8"
                            Margin="0,12,0,0">
                    <Button Content="{loc:Loc research.reveal}"
                            Command="{Binding RevealSelectedCommand}"
                            IsVisible="{Binding SelectedIsFile}"
                            Padding="12,6" />
                    <Button Content="{loc:Loc research.openExternal}"
                            Command="{Binding OpenExternalCommand}"
                            Padding="12,6" />
                    <Button Content="{loc:Loc research.deleteItem}"
                            Command="{Binding DeleteSelectedCommand}"
                            Padding="12,6" />
                    <Button Content="{loc:Loc dialog.save}"
                            Command="{Binding SaveSelectedCommand}"
                            Classes="primary"
                            Padding="14,6" />
                </StackPanel>

                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding SelectedIsImage}"
                        Background="{DynamicResource ExplorerBackground}"
                        CornerRadius="4"
                        Padding="6"
                        Margin="0,12,0,0"
                        MaxHeight="320">
                    <Image Source="{Binding SelectedAbsolutePath, Converter={x:Static conv:AbsolutePathToBitmapConverter.Instance}}"
                           Stretch="Uniform"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                </Border>

                <Border DockPanel.Dock="Top"
                        IsVisible="{Binding SelectedIsFile}"
                        Margin="0,8,0,0">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{loc:Loc research.metadata}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtleText}" />
                        <TextBlock Text="{Binding SelectedAbsolutePath}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SubtleText}"
                                   TextWrapping="Wrap" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource SubtleText}">
                            <Run Text="{Binding SelectedFileSize}" />
                            <Run Text=" · " />
                            <Run Text="{Binding SelectedModified}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,8,0,0">
                    <TextBlock Text="{loc:Loc research.tags}"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleText}" />
                    <ItemsControl ItemsSource="{Binding SelectedItem.Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border CornerRadius="{DynamicResource RadiusPill}"
                                        Background="{DynamicResource AccentBrush}"
                                        Padding="8,2"
                                        Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="White" />
                                        <Button Content="×"
                                                FontSize="11"
                                                Padding="2,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="White"
                                                Command="{Binding $parent[UserControl].((vm:ResearchViewModel)DataContext).RemoveTagCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBox Text="{Binding NewTagText, Mode=TwoWay}"
                                 Watermark="{loc:Loc research.addTag}"
                                 FontSize="11"
                                 MinWidth="180" />
                        <Button Content="+"
                                Command="{Binding AddTagCommand}"
                                Padding="10,4" />
                    </StackPanel>
                </StackPanel>

                <TextBox Text="{Binding SelectedItem.Content, Mode=TwoWay}"
                         Watermark="{loc:Loc research.contentWatermark}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Margin="0,12,0,0"
                         MinHeight="200" />
            </DockPanel>

            <Border Grid.Column="1"
                    IsVisible="{Binding !HasSelection}"
                    Padding="40">
                <TextBlock Text="{loc:Loc research.empty}"
                           FontSize="13"
                           Foreground="{DynamicResource SubtleText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</UserControl>
