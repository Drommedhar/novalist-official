<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svc="using:Novalist.Desktop.Services"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Novalist.Desktop.Views.ExtensionsView"
             x:DataType="svc:ExtensionsViewModel">
    <Border Background="{DynamicResource OverlayScrim}" x:Name="Backdrop" PointerPressed="OnBackdropPressed">
        <Border CornerRadius="12"
                PointerPressed="OnPanelPressed"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="40"
                MaxWidth="1000"
                Background="{DynamicResource CardBackground}">
            <DockPanel Margin="24">
                <!-- Header -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="{loc:Loc extensions.title}"
                               FontSize="{StaticResource FontSizeDisplaySmall}" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button ToolTip.Tip="{loc:Loc extensions.openFolder}"
                                AutomationProperties.Name="{loc:Loc extensions.openFolder}"
                                Command="{Binding OpenExtensionsFolderCommand}"
                                Classes="ribbonButtonSmall">
                            <PathIcon Data="{StaticResource IconFolderOpen}" Width="14" Height="14" Foreground="{DynamicResource NormalText}" />
                        </Button>
                        <Button Content="✕"
                                x:Name="CloseButton"
                                AutomationProperties.Name="{loc:Loc dialog.close}"
                                ToolTip.Tip="{loc:Loc dialog.close}"
                                Classes="ribbonButton"
                                FontSize="{StaticResource FontSizeTitleSmall}"
                                Padding="6,2" />
                    </StackPanel>
                </DockPanel>

                <!-- Tab buttons -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}" Margin="0,0,0,12">
                    <Button Classes="ribbonButtonSmall"
                            FontWeight="{Binding SelectedTab, Converter={x:Static svc:TabFontWeightConverter.Instance}, ConverterParameter=0}"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="0"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <TextBlock Text="{loc:Loc extensions.tabInstalled}" VerticalAlignment="Center" />
                            <Border IsVisible="{Binding UpdateCount}"
                                    Background="{DynamicResource ExtensionUpdateBadge}"
                                    CornerRadius="{StaticResource RadiusLarge}"
                                    Padding="5,1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding UpdateCount}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="White"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                    </Button>
                    <Button Content="{loc:Loc extensions.tabBrowse}"
                            Classes="ribbonButtonSmall"
                            FontWeight="{Binding SelectedTab, Converter={x:Static svc:TabFontWeightConverter.Instance}, ConverterParameter=1}"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="1"
                            Padding="12,6" />
                </StackPanel>

                <!-- ═══ Tab 0: Installed ═══ -->
                <ScrollViewer IsVisible="{Binding SelectedTab, Converter={x:Static svc:TabVisibilityConverter.Instance}, ConverterParameter=0}"
                              HorizontalScrollBarVisibility="Disabled">
                    <DockPanel>
                        <!-- No extensions message -->
                        <TextBlock Text="{loc:Loc extensions.noExtensions}"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   Margin="0,40"
                                   DockPanel.Dock="Top"
                                   IsVisible="{Binding !HasExtensions}" />

                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="svc:ExtensionItemViewModel">
                                    <Border Background="{DynamicResource EditorBackground}"
                                            CornerRadius="{StaticResource RadiusMedium}"
                                            Padding="16,12"
                                            Margin="0,2"
                                            HorizontalAlignment="Stretch">
                                        <DockPanel>
                                            <!-- Enable/Disable toggle -->
                                            <ToggleSwitch DockPanel.Dock="Right"
                                                          IsChecked="{Binding IsEnabled}"
                                                          OffContent=""
                                                          OnContent=""
                                                          VerticalAlignment="Top"
                                                          Margin="12,0,0,0" />

                                            <StackPanel Spacing="{StaticResource SpacingTighter}">
                                                <!-- Name + Version -->
                                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                                    <TextBlock Text="🧩" FontSize="{StaticResource FontSizeTitle}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{StaticResource FontSizeTitleSmall}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Version}"
                                                               Opacity="0.5"
                                                               FontSize="{StaticResource FontSizeBody}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>

                                                <!-- Author -->
                                                <TextBlock Opacity="0.6" FontSize="{StaticResource FontSizeBodySmall}">
                                                    <Run Text="{loc:Loc extensions.author}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding Author}" />
                                                </TextBlock>

                                                <!-- Description -->
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           Opacity="0.7"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           Margin="0,2,0,0" />

                                                <!-- Update / Restart row -->
                                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}" Margin="0,4,0,0"
                                                            IsVisible="{Binding HasUpdate}">
                                                    <Button Command="{Binding UpdateExtensionCommand}"
                                                            Classes="ribbonButtonSmall"
                                                            Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                                                            <TextBlock Text="⬆" FontSize="{StaticResource FontSizeBodySmall}" VerticalAlignment="Center" />
                                                            <TextBlock FontSize="{StaticResource FontSizeBodySmall}" VerticalAlignment="Center">
                                                                <Run Text="{loc:Loc extensions.store.update}" />
                                                                <Run Text=" v" /><Run Text="{Binding AvailableVersion}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Updating indicator -->
                                                <TextBlock IsVisible="{Binding IsUpdating}"
                                                           Text="{loc:Loc extensions.store.updating}"
                                                           FontSize="{StaticResource FontSizeBodySmall}"
                                                           Opacity="0.7"
                                                           Margin="0,4,0,0" />

                                                <!-- Restart required -->
                                                <TextBlock IsVisible="{Binding NeedsRestart}"
                                                           Text="{loc:Loc extensions.restart}"
                                                           FontSize="{StaticResource FontSizeBodySmall}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Margin="0,4,0,0" />

                                                <!-- Error -->
                                                <TextBlock IsVisible="{Binding HasError}"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           FontSize="{StaticResource FontSizeBodySmall}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0">
                                                    <Run Text="{loc:Loc extensions.loadError}" />
                                                    <Run Text=": " />
                                                    <Run Text="{Binding ErrorMessage}" />
                                                </TextBlock>

                                                <!-- Settings button -->
                                                <Button IsVisible="{Binding HasSettings}"
                                                        Tag="{Binding SettingsKey}"
                                                        Click="OnExtensionSettingsClick"
                                                        Classes="ribbonButtonSmall"
                                                        Margin="0,4,0,0"
                                                        Padding="6,2"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                                                        <PathIcon Data="{StaticResource IconSettings}" Width="12" Height="12" Foreground="{DynamicResource NormalText}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{loc:Loc extensions.settings}" FontSize="{StaticResource FontSizeBodySmall}" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </ScrollViewer>

                <!-- ═══ Tab 1: Browse Store ═══ -->
                <Border IsVisible="{Binding SelectedTab, Converter={x:Static svc:TabVisibilityConverter.Instance}, ConverterParameter=1}">
                    <Grid DataContext="{Binding Store}" x:DataType="svc:ExtensionStoreViewModel">

                        <!-- Browse list (hidden when detail is visible) -->
                        <DockPanel IsVisible="{Binding !IsDetailVisible}">
                            <!-- Search bar -->
                            <TextBox DockPanel.Dock="Top"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="{loc:Loc extensions.store.search}"
                                     Margin="0,0,0,8" />

                            <!-- Loading indicator -->
                            <StackPanel IsVisible="{Binding IsLoading}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{loc:Loc extensions.store.loading}"
                                           Opacity="0.5"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Error -->
                            <StackPanel IsVisible="{Binding HasError}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="{StaticResource SpacingMedium}">
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center" />
                                <Button Content="{loc:Loc extensions.store.retry}"
                                        Command="{Binding LoadCommand}"
                                        HorizontalAlignment="Center"
                                        Classes="ribbonButtonSmall"
                                        Padding="12,6" />
                            </StackPanel>

                            <!-- Empty state -->
                            <TextBlock IsVisible="{Binding IsEmpty}"
                                       Text="{loc:Loc extensions.store.empty}"
                                       Opacity="0.5"
                                       HorizontalAlignment="Center"
                                       Margin="0,40" />

                            <!-- Extension cards -->
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="svc:StoreExtensionItemViewModel">
                                            <Border Background="{DynamicResource EditorBackground}"
                                                    CornerRadius="{StaticResource RadiusMedium}"
                                                    Padding="16,12"
                                                    Margin="0,2"
                                                    IsVisible="{Binding IsVisible}"
                                                    Cursor="Hand"
                                                    x:Name="StoreCard"
                                                    PointerPressed="OnStoreCardPressed">
                                                <DockPanel>
                                                    <!-- Action button -->
                                                    <StackPanel DockPanel.Dock="Right"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,0,0"
                                                                Spacing="{StaticResource SpacingTighter}">
                                                        <!-- Install button -->
                                                        <Button Content="{loc:Loc extensions.store.install}"
                                                                IsVisible="{Binding !IsInstalled}"
                                                                IsEnabled="{Binding IsCompatible}"
                                                                Click="OnInstallClicked"
                                                                Tag="{Binding}"
                                                                Classes="ribbonButtonSmall"
                                                                Padding="12,6" />
                                                        <!-- Installed indicator -->
                                                        <TextBlock Text="✓"
                                                                   IsVisible="{Binding IsInstalled}"
                                                                   FontSize="{StaticResource FontSizeTitle}"
                                                                   Foreground="{DynamicResource ExtensionInstalledBrush}"
                                                                   HorizontalAlignment="Center" />
                                                    </StackPanel>

                                                    <StackPanel Spacing="{StaticResource SpacingTighter}">
                                                        <!-- Name + Version -->
                                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                                            <TextBlock Text="📦" FontSize="{StaticResource FontSizeTitle}" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="{StaticResource FontSizeTitleSmall}"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding LatestVersion}"
                                                                       Opacity="0.5"
                                                                       FontSize="{StaticResource FontSizeBody}"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>

                                                        <!-- Author -->
                                                        <TextBlock Opacity="0.6" FontSize="{StaticResource FontSizeBodySmall}">
                                                            <Run Text="{loc:Loc extensions.author}" />
                                                            <Run Text=" " />
                                                            <Run Text="{Binding Author}" />
                                                        </TextBlock>

                                                        <!-- Description -->
                                                        <TextBlock Text="{Binding Description}"
                                                                   TextWrapping="Wrap"
                                                                   Opacity="0.7"
                                                                   FontSize="{StaticResource FontSizeBody}"
                                                                   MaxLines="2"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0" />

                                                        <!-- Tags -->
                                                        <ItemsControl ItemsSource="{Binding Tags}" IsVisible="{Binding Tags.Count}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="x:String">
                                                                    <Border Background="{DynamicResource EditorBackground}"
                                                                            CornerRadius="3"
                                                                            Padding="6,2"
                                                                            Margin="0,2,4,0"
                                                                            BorderBrush="{DynamicResource SubtleText}"
                                                                            BorderThickness="1"
                                                                            Opacity="0.6">
                                                                        <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeCaption}" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <!-- Install progress -->
                                                        <ProgressBar IsVisible="{Binding IsInstalling}"
                                                                     Value="{Binding InstallProgress}"
                                                                     Maximum="1"
                                                                     Height="4"
                                                                     Margin="0,4,0,0" />

                                                        <!-- Install error -->
                                                        <TextBlock IsVisible="{Binding InstallError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                   Text="{Binding InstallError}"
                                                                   Foreground="{DynamicResource DangerBrush}"
                                                                   FontSize="{StaticResource FontSizeBodySmall}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- ═══ Detail view ═══ -->
                        <DockPanel IsVisible="{Binding IsDetailVisible}">
                            <!-- Back button -->
                            <Button DockPanel.Dock="Top"
                                    Content="← Back"
                                    Command="{Binding HideDetailCommand}"
                                    Classes="ribbonButtonSmall"
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,8" />

                            <!-- Header + actions (fixed top) -->
                            <StackPanel DockPanel.Dock="Top" Spacing="{StaticResource SpacingLarge}"
                                        DataContext="{Binding SelectedItem}" x:DataType="svc:StoreExtensionItemViewModel">
                                <StackPanel Spacing="{StaticResource SpacingTighter}">
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                        <TextBlock Text="📦" FontSize="{StaticResource FontSizeDisplaySmall}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{StaticResource FontSizeDisplaySmall}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LatestVersion}"
                                                   Opacity="0.5"
                                                   FontSize="{StaticResource FontSizeTitleSmall}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Opacity="0.6" FontSize="{StaticResource FontSizeBody}">
                                        <Run Text="{loc:Loc extensions.author}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding Author}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}"
                                               TextWrapping="Wrap"
                                               Opacity="0.7"
                                               FontSize="{StaticResource FontSizeBodyLarge}" />
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                    <Button Content="{loc:Loc extensions.store.install}"
                                            IsVisible="{Binding !IsInstalled}"
                                            IsEnabled="{Binding IsCompatible}"
                                            Click="OnDetailInstallClicked"
                                            Classes="ribbonButtonSmall"
                                            Padding="16,8" />
                                    <Button Content="{loc:Loc extensions.store.uninstall}"
                                            IsVisible="{Binding IsInstalled}"
                                            Click="OnDetailUninstallClicked"
                                            Classes="ribbonButtonSmall"
                                            Padding="16,8" />
                                    <Button Content="{Binding StatusText}"
                                            IsVisible="{Binding HasUpdate}"
                                            Click="OnDetailUpdateClicked"
                                            Classes="ribbonButtonSmall"
                                            Padding="16,8" />
                                </StackPanel>

                                <!-- Progress -->
                                <ProgressBar IsVisible="{Binding IsInstalling}"
                                             Value="{Binding InstallProgress}"
                                             Maximum="1"
                                             Height="4" />

                                <Separator Margin="0,4" />
                            </StackPanel>

                            <!-- Metadata (fixed bottom) -->
                            <StackPanel DockPanel.Dock="Bottom" Spacing="{StaticResource SpacingTightest}" Margin="0,8,0,0"
                                        DataContext="{Binding SelectedItem}" x:DataType="svc:StoreExtensionItemViewModel">
                                <Separator Margin="0,0,0,8" />
                                <TextBlock Opacity="0.5" FontSize="{StaticResource FontSizeBodySmall}">
                                    <Run Text="Repository: " />
                                    <Run Text="{Binding Repo}" />
                                </TextBlock>
                                <TextBlock Opacity="0.5" FontSize="{StaticResource FontSizeBodySmall}">
                                    <Run Text="Tags: " />
                                    <Run Text="{Binding Tags, Converter={x:Static svc:TagsJoinConverter.Instance}, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- README + Release notes WebView (fills remaining space) -->
                            <Grid x:Name="ReadmeWebViewHost" Margin="0,4" />
                        </DockPanel>
                    </Grid>
                </Border>

            </DockPanel>
        </Border>
    </Border>
</UserControl>
