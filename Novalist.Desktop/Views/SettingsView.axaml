<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             xmlns:glass="using:LiquidGlassAvaloniaUI"
             xmlns:views="using:Novalist.Desktop.Views"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <glass:LiquidGlassSurface CornerRadius="0">
    <Grid ColumnDefinitions="220,*">

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource RibbonGroupBorder}"
                BorderThickness="0,0,1,0"
                Padding="0,16,0,0">
            <DockPanel>
                <!-- Header + Close -->
                <DockPanel DockPanel.Dock="Top" Margin="16,0,16,12">
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            x:Name="CloseButton"
                            Classes="ribbonButton"
                            FontSize="14"
                            Padding="6,2"
                            VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Loc settings.title}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NormalText}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Search Box -->
                <Border DockPanel.Dock="Top" Margin="16,0,16,16">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery, Mode=TwoWay}"
                             Watermark="{loc:Loc settings.searchPlaceholder}"
                             FontSize="12"
                             Padding="8,6" />
                </Border>

                <!-- Category List -->
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Margin="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="24,8"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="{DynamicResource NormalText}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="CornerRadius" Value="0"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SettingsCategoryItem">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN SETTINGS AREA ═══ -->
        <ScrollViewer Grid.Column="1"
                      x:Name="SettingsScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,24,40,40" Spacing="32" MaxWidth="640">

                <!-- ── Language Section ── -->
                <StackPanel x:Name="SectionLanguage" Spacing="16"
                            IsVisible="{Binding IsLanguageSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.language}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                            <TextBlock Text="{loc:Loc settings.uiLanguage}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.uiLanguageDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableUiLanguages}"
                                  SelectedItem="{Binding SelectedUiLanguage}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Theme -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                            <TextBlock Text="{loc:Loc settings.theme}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.themeDescription}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Editor Section ── -->
                <StackPanel x:Name="SectionEditor" Spacing="16"
                            IsVisible="{Binding IsEditorSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.editor}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <!-- Font Family -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                            <TextBlock Text="{loc:Loc settings.fontFamily}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.fontFamilyDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding EditorFontFamily}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Font Size -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                            <TextBlock Text="{loc:Loc settings.fontSize}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.fontSizeDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding EditorFontSize}"
                                       Minimum="8"
                                       Maximum="36"
                                       Increment="1"
                                       FormatString="0"
                                       MinWidth="120"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Book Paragraph Spacing -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="360">
                            <TextBlock Text="{loc:Loc settings.bookSpacing}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.bookSpacingDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding EnableBookParagraphSpacing}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <!-- Book Page Width -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="360">
                            <TextBlock Text="{loc:Loc settings.bookWidth}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.bookWidthDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding EnableBookWidth}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <StackPanel Spacing="12"
                                IsVisible="{Binding EnableBookWidth}">
                        <!-- Page Format -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthPageFormat}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="13" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AvailablePageFormats}"
                                      SelectedItem="{Binding SelectedPageFormat}"
                                      MinWidth="200"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Custom Width -->
                        <DockPanel IsVisible="{Binding IsCustomPageFormat}">
                            <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthCustom}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="13" />
                                <TextBlock Text="{loc:Loc settings.bookWidthCustomDesc}"
                                           Foreground="{DynamicResource SubtleText}"
                                           FontSize="11" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding BookTextBlockWidth}"
                                           Minimum="2"
                                           Maximum="10"
                                           Increment="0.25"
                                           FormatString="0.##"
                                           MinWidth="120"
                                           HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Book Font -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthFont}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="13" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AvailableFonts}"
                                      SelectedItem="{Binding BookFontFamily}"
                                      MinWidth="200"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Book Font Size -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="2" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthFontSize}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="13" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding BookFontSize}"
                                           Minimum="6"
                                           Maximum="24"
                                           Increment="0.5"
                                           FormatString="0.#"
                                           MinWidth="120"
                                           HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Chars per line preview -->
                        <TextBlock Text="{Binding BookWidthCharsPerLine}"
                                   Foreground="{DynamicResource SubtleText}"
                                   FontSize="11"
                                   FontStyle="Italic" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Writing Goals Section ── -->
                <StackPanel x:Name="SectionWritingGoals" Spacing="16"
                            IsVisible="{Binding IsWritingGoalsSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.writingGoals}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding CurrentProjectName}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc settings.goalsDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="300">
                            <TextBlock Text="{loc:Loc settings.dailyWordGoal}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.dailyWordGoalDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding DailyWordGoal}"
                                       Minimum="0"
                                       Maximum="1000000"
                                       Increment="100"
                                       FormatString="0"
                                       MinWidth="140"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="300">
                            <TextBlock Text="{loc:Loc settings.projectWordGoal}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.projectWordGoalDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding ProjectWordGoal}"
                                       Minimum="0"
                                       Maximum="10000000"
                                       Increment="1000"
                                       FormatString="0"
                                       MinWidth="140"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="300">
                            <TextBlock Text="{loc:Loc settings.projectDeadline}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.projectDeadlineDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox Text="{Binding ProjectDeadline}"
                                 Watermark="YYYY-MM-DD"
                                 MinWidth="140"
                                 HorizontalAlignment="Right" />
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Auto-Replacement Section ── -->
                <StackPanel x:Name="SectionAutoReplacement" Spacing="16"
                            IsVisible="{Binding IsAutoReplacementSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.autoReplacement}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <!-- Language -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="300">
                            <TextBlock Text="{loc:Loc settings.quoteStyle}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.quoteStyleDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Dialogue Correction -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="300">
                            <TextBlock Text="{loc:Loc settings.dialogueCorrection}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc settings.dialogueCorrectionDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding DialogueCorrectionEnabled}"
                                      HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Preview -->
                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc settings.preview}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtleText}" />
                            <TextBlock Text="{Binding AutoReplacementPreview}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       FontFamily="Cascadia Mono, Consolas, monospace" />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Templates Section ── -->
                <StackPanel x:Name="SectionTemplates" Spacing="16"
                            IsVisible="{Binding IsTemplatesSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.templates}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <!-- Character Templates -->
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <TextBlock Text="{loc:Loc settings.characterTemplates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="+"
                                    Command="{Binding AddCharacterTemplateCommand}"
                                    Padding="8,4"
                                    FontSize="14"
                                    HorizontalAlignment="Right"
                                    ToolTip.Tip="{loc:Loc template.addTemplate}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding CharacterTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteCharacterTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditCharacterTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Location Templates -->
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <TextBlock Text="{loc:Loc settings.locationTemplates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="+"
                                    Command="{Binding AddLocationTemplateCommand}"
                                    Padding="8,4"
                                    FontSize="14"
                                    HorizontalAlignment="Right"
                                    ToolTip.Tip="{loc:Loc template.addTemplate}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding LocationTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteLocationTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditLocationTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Item Templates -->
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <TextBlock Text="{loc:Loc settings.itemTemplates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="+"
                                    Command="{Binding AddItemTemplateCommand}"
                                    Padding="8,4"
                                    FontSize="14"
                                    HorizontalAlignment="Right"
                                    ToolTip.Tip="{loc:Loc template.addTemplate}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding ItemTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteItemTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditItemTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Lore Templates -->
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <TextBlock Text="{loc:Loc settings.loreTemplates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="+"
                                    Command="{Binding AddLoreTemplateCommand}"
                                    Padding="8,4"
                                    FontSize="14"
                                    HorizontalAlignment="Right"
                                    ToolTip.Tip="{loc:Loc template.addTemplate}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding LoreTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteLoreTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditLoreTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- ── Keyboard Shortcuts Section ── -->
                <StackPanel x:Name="SectionHotkeys" Spacing="16"
                            IsVisible="{Binding IsHotkeysSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.hotkeys}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <views:HotkeySettingsView DataContext="{Binding HotkeySettings}" />

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── General Section ── -->
                <StackPanel x:Name="SectionGeneral" Spacing="16"
                            IsVisible="{Binding IsGeneralSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.general}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="2" Width="360">
                            <TextBlock Text="{loc:Loc update.checkForUpdates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="13" />
                            <TextBlock Text="{loc:Loc update.checkForUpdatesDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding CheckForUpdates}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Extension Settings Sections ── -->
                <ItemsControl x:Name="SectionExtensions" ItemsSource="{Binding ExtensionSettingsPages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ExtensionSettingsPageVM">
                            <StackPanel Spacing="12" Margin="0,16,0,0">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtleText}"
                                           LetterSpacing="1" />
                                <ContentControl Content="{Binding View}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
    </glass:LiquidGlassSurface>
</UserControl>
