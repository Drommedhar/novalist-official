<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             xmlns:conv="using:Novalist.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.CodexHubView"
             x:DataType="vm:CodexHubViewModel">

    <UserControl.Resources>
        <conv:RelativePathToBitmapConverter x:Key="PathToBitmap" />
    </UserControl.Resources>

    <Border Background="{DynamicResource EditorBackground}">
        <DockPanel Margin="32,24,32,24">

            <!-- Loading bar -->
            <ProgressBar DockPanel.Dock="Top"
                         IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Height="2"
                         Margin="0,0,0,0"
                         CornerRadius="{StaticResource RadiusNone}" />

            <!-- Header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <StackPanel Grid.Column="0" Spacing="{StaticResource SpacingTighter}">
                    <TextBlock Text="{loc:Loc codexHub.title}"
                               FontSize="{DynamicResource FontSizeTitle}"
                               FontWeight="{DynamicResource FontWeightTitle}"
                               Foreground="{DynamicResource NormalText}" />
                    <TextBlock Text="{loc:Loc codexHub.subtitle}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               Foreground="{DynamicResource SubtleText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}" VerticalAlignment="Center">
                    <ComboBox SelectedIndex="{Binding SortModeIndex, Mode=TwoWay}"
                              MinWidth="160"
                              FontSize="{StaticResource FontSizeBody}">
                        <ComboBoxItem Content="{loc:Loc codexHub.sortName}" />
                        <ComboBoxItem Content="{loc:Loc codexHub.sortNameDesc}" />
                    </ComboBox>
                    <Button Command="{Binding ManageEntityTypesCommand}"
                            FontSize="{StaticResource FontSizeBody}">
                        <TextBlock Text="{loc:Loc codexHub.manageTypes}" />
                    </Button>
                    <Button Command="{Binding OpenTemplatesCommand}"
                            FontSize="{StaticResource FontSizeBody}">
                        <TextBlock Text="{loc:Loc codexHub.templates}" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Search Bar -->
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding SearchQuery, Mode=TwoWay}"
                     Watermark="{loc:Loc codexHub.searchPlaceholder}"
                     Padding="10,8"
                     FontSize="{StaticResource FontSizeBodyLarge}"
                     Margin="0,0,0,12" />

            <!-- Filter pills -->
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="{StaticResource SpacingTighter}"
                        Margin="0,0,0,20">
                <Button Command="{Binding SetTabCommand}" CommandParameter="All"
                        Classes="codexFilterPill"
                        Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=All}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <TextBlock Text="{loc:Loc codexHub.all}" />
                        <Border Background="#30808080"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="5,1" MinWidth="20">
                            <TextBlock Text="{Binding TotalCount}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SetTabCommand}" CommandParameter="Character"
                        Classes="codexFilterPill"
                        Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Character}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconUser}"/></Canvas></Viewbox>
                        <TextBlock Text="{loc:Loc codexHub.characters}" />
                        <Border Background="#30808080"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="5,1" MinWidth="20">
                            <TextBlock Text="{Binding CharacterCount}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SetTabCommand}" CommandParameter="Location"
                        Classes="codexFilterPill"
                        Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Location}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconMapPin}"/></Canvas></Viewbox>
                        <TextBlock Text="{loc:Loc codexHub.locations}" />
                        <Border Background="#30808080"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="5,1" MinWidth="20">
                            <TextBlock Text="{Binding LocationCount}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SetTabCommand}" CommandParameter="Item"
                        Classes="codexFilterPill"
                        Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Item}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconSword}"/></Canvas></Viewbox>
                        <TextBlock Text="{loc:Loc codexHub.items}" />
                        <Border Background="#30808080"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="5,1" MinWidth="20">
                            <TextBlock Text="{Binding ItemCount}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SetTabCommand}" CommandParameter="Lore"
                        Classes="codexFilterPill"
                        Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Lore}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                        <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconScroll}"/></Canvas></Viewbox>
                        <TextBlock Text="{loc:Loc codexHub.lore}" />
                        <Border Background="#30808080"
                                CornerRadius="{DynamicResource RadiusPill}"
                                Padding="5,1" MinWidth="20">
                            <TextBlock Text="{Binding LoreCount}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Button>

                <ComboBox ItemsSource="{Binding CustomTabs}"
                          SelectedItem="{Binding SelectedCustomTab}"
                          Padding="10,5"
                          FontSize="{StaticResource FontSizeBody}"
                          MinWidth="140"
                          IsVisible="{Binding CustomTabs.Count}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CodexCustomTab">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                <TextBlock Text="{Binding Icon}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DisplayName}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center" />
                                <Border Background="#30808080"
                                        CornerRadius="{DynamicResource RadiusPill}"
                                        Padding="5,1" MinWidth="20" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Count}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Entity Grid -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredEntities}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CodexEntityItem">
                            <Button Classes="imageThumbButton"
                                    Command="{Binding $parent[ItemsControl].((vm:CodexHubViewModel)DataContext).OpenEntityCommand}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,12,12"
                                    Padding="0"
                                    Width="240">
                                <Border Classes="nlvCard"
                                        Padding="0"
                                        ClipToBounds="True">
                                    <StackPanel>
                                        <!-- Image / icon area — always 120px tall -->
                                        <Border Height="120"
                                                Background="{DynamicResource ExplorerBackground}">
                                            <Panel>
                                                <!-- Portrait when available -->
                                                <Image Source="{Binding ImagePath, Converter={StaticResource PathToBitmap}}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality"
                                                       IsVisible="{Binding HasImage}" />
                                                <!-- Icon placeholder -->
                                                <Panel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding !HasImage}">
                                                    <PathIcon Data="{Binding Icon, Converter={x:Static conv:StringToGeometryConverter.Instance}}"
                                                              Width="28" Height="28"
                                                              Foreground="{DynamicResource SubtleText}"
                                                              IsVisible="{Binding !IsEmoji}" />
                                                    <TextBlock Text="{Binding Icon}"
                                                               FontSize="{StaticResource FontSizeDisplay}"
                                                               IsVisible="{Binding IsEmoji}" />
                                                </Panel>
                                            </Panel>
                                        </Border>

                                        <!-- Info section -->
                                        <Border Padding="12,10,12,12">
                                        <StackPanel Spacing="3">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource NormalText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="{DynamicResource RadiusSmall}"
                                                        Padding="4,1"
                                                        IsVisible="{Binding IsWorldBible}"
                                                        VerticalAlignment="Center"
                                                        Margin="6,0,0,0">
                                                    <TextBlock Text="WB"
                                                               FontSize="{StaticResource FontSizeTiny}"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Subtitle}"
                                                       FontSize="{StaticResource FontSizeBodySmall}"
                                                       Foreground="{DynamicResource SubtleText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
