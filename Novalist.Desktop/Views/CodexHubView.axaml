<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             xmlns:conv="using:Novalist.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.CodexHubView"
             x:DataType="vm:CodexHubViewModel">

    <Border Background="{DynamicResource EditorBackground}">
        <!-- SpacingXXL=20, SpacingLarge=12 -->
        <DockPanel Margin="20,20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
                <TextBlock Text="{loc:Loc codexHub.title}"
                           FontSize="{DynamicResource FontSizeTitle}"
                           FontWeight="{DynamicResource FontWeightTitle}"
                           Foreground="{DynamicResource NormalText}" />
                <TextBlock Text="{loc:Loc codexHub.subtitle}"
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           Foreground="{DynamicResource SubtleText}" />
            </StackPanel>

            <!-- Search Bar -->
            <Border DockPanel.Dock="Top"
                    Margin="0,0,0,12"
                    MaxWidth="860"
                    HorizontalAlignment="Stretch">
                <TextBox Text="{Binding SearchQuery, Mode=TwoWay}"
                         Watermark="{loc:Loc codexHub.searchPlaceholder}"
                         Padding="10,8"
                         FontSize="14" />
            </Border>

            <!-- Tabs: All | Characters | Locations | Items | Lore -->
            <Border DockPanel.Dock="Top"
                    Margin="0,0,0,16"
                    MaxWidth="860"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <!-- All -->
                    <Button Command="{Binding SetTabCommand}" CommandParameter="All"
                            Classes="ribbonToggleLarge"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=All}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{loc:Loc codexHub.all}" FontSize="13" />
                            <!-- RadiusPill for badge -->
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}"
                                    Padding="6,1" MinWidth="24">
                                <TextBlock Text="{Binding TotalCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Characters -->
                    <Button Command="{Binding SetTabCommand}" CommandParameter="Character"
                            Classes="ribbonToggleLarge"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Character}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconUser}"/></Canvas></Viewbox>
                            <TextBlock Text="{loc:Loc codexHub.characters}" FontSize="13" />
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}"
                                    Padding="6,1" MinWidth="24">
                                <TextBlock Text="{Binding CharacterCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Locations -->
                    <Button Command="{Binding SetTabCommand}" CommandParameter="Location"
                            Classes="ribbonToggleLarge"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Location}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconMapPin}"/></Canvas></Viewbox>
                            <TextBlock Text="{loc:Loc codexHub.locations}" FontSize="13" />
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}"
                                    Padding="6,1" MinWidth="24">
                                <TextBlock Text="{Binding LocationCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Items -->
                    <Button Command="{Binding SetTabCommand}" CommandParameter="Item"
                            Classes="ribbonToggleLarge"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Item}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconSword}"/></Canvas></Viewbox>
                            <TextBlock Text="{loc:Loc codexHub.items}" FontSize="13" />
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}"
                                    Padding="6,1" MinWidth="24">
                                <TextBlock Text="{Binding ItemCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Lore -->
                    <Button Command="{Binding SetTabCommand}" CommandParameter="Lore"
                            Classes="ribbonToggleLarge"
                            Classes.active="{Binding ActiveTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Lore}"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Viewbox Classes="inlineIcon"><Canvas Width="24" Height="24"><Path Classes="inlineIcon" Data="{StaticResource IconScroll}"/></Canvas></Viewbox>
                            <TextBlock Text="{loc:Loc codexHub.lore}" FontSize="13" />
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}"
                                    Padding="6,1" MinWidth="24">
                                <TextBlock Text="{Binding LoreCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Dynamic custom entity type dropdown -->
                    <ComboBox ItemsSource="{Binding CustomTabs}"
                              SelectedItem="{Binding SelectedCustomTab}"
                              Padding="12,6"
                              FontSize="13"
                              MinWidth="160"
                              IsVisible="{Binding CustomTabs.Count}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:CodexCustomTab">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center" />
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="{DynamicResource RadiusPill}"
                                            Padding="6,1" MinWidth="24" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Count}"
                                                   FontSize="11"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Entity Grid -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredEntities}"
                              MaxWidth="860"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CodexEntityItem">
                            <!-- Use NlvCard for consistent card style -->
                            <Button Classes="imageThumbButton"
                                    Command="{Binding $parent[ItemsControl].((vm:CodexHubViewModel)DataContext).OpenEntityCommand}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,10,10"
                                    Padding="0">
                                <Border Classes="nlvCard"
                                        Width="200"
                                        Padding="16,12">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Icon path -->
                                            <PathIcon Grid.Column="0"
                                                      Data="{Binding Icon, Converter={x:Static conv:StringToGeometryConverter.Instance}}"
                                                      Width="18" Height="18"
                                                      Foreground="{DynamicResource NormalText}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      IsVisible="{Binding !IsEmoji}" />
                                            <!-- Emoji icon -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       IsVisible="{Binding IsEmoji}" />
                                            <!-- Name -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource NormalText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <!-- World Bible badge -->
                                            <TextBlock Grid.Column="2"
                                                       Text="WB"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding IsWorldBible}" />
                                        </Grid>
                                        <!-- Subtitle -->
                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtleText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>