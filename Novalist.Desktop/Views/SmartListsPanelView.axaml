<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             x:Class="Novalist.Desktop.Views.SmartListsPanelView"
             x:DataType="vm:ExplorerViewModel">
    <Border Background="{DynamicResource ExplorerBackground}"
            BorderBrush="{DynamicResource ExplorerBorder}"
            BorderThickness="0,0,1,0">
        <DockPanel>
            <Border DockPanel.Dock="Top" Padding="12,8">
                <TextBlock Text="{loc:Loc smartList.section}"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DimText}" />
            </Border>

            <Border DockPanel.Dock="Top"
                    Padding="8,4"
                    BorderBrush="{DynamicResource ExplorerBorder}"
                    BorderThickness="0,1,0,1">
                <Button Content="{loc:Loc smartList.addNew}"
                        Command="{Binding CreateSmartListCommand}"
                        FontSize="{StaticResource FontSizeBodySmall}"
                        Padding="10,4"
                        HorizontalAlignment="Stretch" />
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SmartLists}" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SmartListItemViewModel">
                            <StackPanel>
                                <!-- Header — same look as Act headers -->
                                <Border Padding="8,8,8,4"
                                        Margin="4,6,4,0"
                                        Tag="{Binding}"
                                        Cursor="Hand"
                                        PointerPressed="OnSmartListHeaderPressed">
                                    <Border.ContextMenu>
                                        <ContextMenu Tag="{Binding}">
                                            <MenuItem Header="{loc:Loc smartList.edit}"
                                                      Click="OnEditSmartListClick" />
                                            <MenuItem Header="{loc:Loc smartList.refresh}"
                                                      Click="OnRefreshSmartListClick" />
                                            <Separator />
                                            <MenuItem Header="{loc:Loc smartList.delete}"
                                                      Click="OnDeleteSmartListClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource SubtleText}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>

                                <StackPanel IsVisible="{Binding IsExpanded}" Margin="0,0,0,4">
                                    <TextBlock Text="{loc:Loc smartList.loading}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Opacity="0.6"
                                               Margin="14,2"
                                               IsVisible="{Binding IsLoading}" />
                                    <ItemsControl ItemsSource="{Binding Matches}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SmartListSceneEntryViewModel">
                                                <Button Content="{Binding DisplayLabel}"
                                                        Command="{Binding OpenCommand}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="{StaticResource FontSizeBodySmall}"
                                                        Padding="14,3"
                                                        Foreground="{DynamicResource DimText}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
