<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.GitView"
             x:DataType="vm:GitViewModel">

    <Border Background="{DynamicResource EditorBackground}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="860"
                        HorizontalAlignment="Center"
                        Margin="32,24"
                        Spacing="20">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{loc:Loc git.title}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource NormalText}" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsGitRepo}">
                            <TextBlock Text="⎇" FontSize="14"
                                       Foreground="{DynamicResource SubtleText}" />
                            <TextBlock Text="{Binding BranchName}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource NormalText}" />
                            <TextBlock Text="{Binding SyncDisplay}"
                                       FontSize="13"
                                       Foreground="{DynamicResource DimText}"
                                       IsVisible="{Binding HasRemote}"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Top"
                                IsVisible="{Binding IsGitRepo}">
                        <Button Content="{loc:Loc git.refresh}"
                                Command="{Binding RefreshCommand}"
                                Classes="ribbonButtonSmall"
                                Padding="12,6" FontSize="11" />
                        <Button Content="{loc:Loc git.pull}"
                                Command="{Binding PullCommand}"
                                Classes="ribbonButtonSmall"
                                Padding="12,6" FontSize="11"
                                IsVisible="{Binding HasRemote}" />
                        <Button Content="{loc:Loc git.push}"
                                Command="{Binding PushCommand}"
                                Classes="ribbonButtonSmall"
                                Padding="12,6" FontSize="11"
                                IsVisible="{Binding HasRemote}" />
                    </StackPanel>
                </Grid>

                <!-- Git not installed message -->
                <Border Padding="16"
                        CornerRadius="8"
                        Background="{DynamicResource ExplorerBackground}"
                        IsVisible="{Binding IsGitInstalled, Converter={x:Static BoolConverters.Not}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc git.notInstalled}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock Text="{loc:Loc git.notInstalledHint}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource DimText}" />
                    </StackPanel>
                </Border>

                <!-- Not a git repo message -->
                <Border Padding="16"
                        CornerRadius="8"
                        Background="{DynamicResource ExplorerBackground}"
                        IsVisible="{Binding !IsGitRepo}">
                    <StackPanel Spacing="8"
                                IsVisible="{Binding IsGitInstalled}">
                        <TextBlock Text="{loc:Loc git.notARepo}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock Text="{loc:Loc git.notARepoHint}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource DimText}" />
                    </StackPanel>
                </Border>

                <!-- Loading indicator -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsLoading}">
                    <TextBlock Text="{loc:Loc git.loading}"
                               FontSize="12"
                               Foreground="{DynamicResource SubtleText}" />
                </StackPanel>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource DimText}" />

                <!-- Main git content (only when in a repo) -->
                <StackPanel Spacing="16"
                            IsVisible="{Binding IsGitRepo}">

                    <!-- No changes message -->
                    <Border Padding="16"
                            CornerRadius="8"
                            Background="{DynamicResource ExplorerBackground}"
                            IsVisible="{Binding !HasChanges}">
                        <TextBlock Text="{loc:Loc git.noChanges}"
                                   FontSize="13"
                                   Foreground="{DynamicResource DimText}" />
                    </Border>

                    <!-- Changed files section -->
                    <StackPanel Spacing="8"
                                IsVisible="{Binding HasChanges}">

                        <!-- Section header with actions -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{loc:Loc git.changedFiles}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource NormalText}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <Button Content="{loc:Loc git.stageAll}"
                                        Command="{Binding StageAllCommand}"
                                        Classes="ribbonButtonSmall"
                                        Padding="8,4" FontSize="10" />
                                <Button Content="{loc:Loc git.unstageAll}"
                                        Command="{Binding UnstageAllCommand}"
                                        Classes="ribbonButtonSmall"
                                        Padding="8,4" FontSize="10" />
                            </StackPanel>
                        </Grid>

                        <!-- File list -->
                        <Border CornerRadius="6"
                                Background="{DynamicResource ExplorerBackground}"
                                Padding="4">
                            <ItemsControl ItemsSource="{Binding ChangedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GitFileItemViewModel">
                                        <Border Padding="8,5"
                                                CornerRadius="4"
                                                Margin="2,1">
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                <!-- Checkbox for staging -->
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsStaged}"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center" />

                                                <!-- Status badge -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding StatusLabel}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           FontFamily="Consolas,monospace"
                                                           Width="20"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"
                                                           Foreground="{Binding StatusBrush}" />

                                                <!-- File path -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Spacing="0">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource NormalText}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Directory}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SubtleText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               IsVisible="{Binding Directory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Commit section -->
                        <Border CornerRadius="6"
                                Background="{DynamicResource ExplorerBackground}"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{loc:Loc git.commitMessage}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource NormalText}" />
                                <TextBox Text="{Binding CommitMessage}"
                                         Watermark="{loc:Loc git.commitPlaceholder}"
                                         AcceptsReturn="True"
                                         MinHeight="60"
                                         MaxHeight="120"
                                         TextWrapping="Wrap"
                                         FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="{loc:Loc git.commitStaged}"
                                            Command="{Binding CommitSelectedCommand}"
                                            Classes="ribbonButtonSmall"
                                            Padding="12,6" FontSize="11"
                                            IsEnabled="{Binding HasStagedChanges}" />
                                    <Button Content="{loc:Loc git.commitAll}"
                                            Command="{Binding CommitAllCommand}"
                                            Classes="ribbonButtonSmall"
                                            Padding="12,6" FontSize="11" />
                                    <Button Content="{loc:Loc git.discardUnstaged}"
                                            Command="{Binding DiscardSelectedCommand}"
                                            Classes="ribbonButtonSmall"
                                            Padding="12,6" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
