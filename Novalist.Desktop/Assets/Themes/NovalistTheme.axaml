<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS Code Dark+ inspired, refined for modern polish -->

    <!-- Core surfaces -->
    <SolidColorBrush x:Key="RibbonBackground" Color="#252526" />
    <SolidColorBrush x:Key="RibbonBorder" Color="#333333" />
    <SolidColorBrush x:Key="RibbonGroupBorder" Color="#333333" />
    <SolidColorBrush x:Key="ActivityBarBackground" Color="#1E1E1E" />

    <!-- Status bar (accent-based, slightly softer) -->
    <SolidColorBrush x:Key="StatusBarBackground" Color="#006AB3" />
    <SolidColorBrush x:Key="StatusBarForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="StatusBarSecondaryForeground" Color="#B3D9FF" />
    <SolidColorBrush x:Key="StatusBarHoverBackground" Color="#1F8AD2" />

    <!-- Explorer / side panels -->
    <SolidColorBrush x:Key="ExplorerBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ExplorerBorder" Color="#303030" />

    <!-- Editor & welcome -->
    <SolidColorBrush x:Key="EditorBackground" Color="#181818" />
    <SolidColorBrush x:Key="WelcomeBackground" Color="#181818" />

    <!-- Page-view paper surface — themed; matches the dark card aesthetic. -->
    <SolidColorBrush x:Key="EditorPageBackground" Color="#1F2127" />
    <SolidColorBrush x:Key="EditorPageForeground" Color="#E6EDF3" />

    <!-- Cards / elevated surfaces -->
    <SolidColorBrush x:Key="CardBackground" Color="#252526" />
    <SolidColorBrush x:Key="CardBorder" Color="#333333" />

    <!-- Accent (primary) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0E8BDF" />
    <SolidColorBrush x:Key="AccentBrushHover" Color="#2D9EE6" />
    <SolidColorBrush x:Key="AccentForeground" Color="#FFFFFF" />

    <!-- Semantic colors (for success/warning/danger) -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#1DB954" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F5A623" />
    <SolidColorBrush x:Key="DangerBrush" Color="#E74C3C" />

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="NormalText" Color="#E6EDF3" />
    <SolidColorBrush x:Key="DimText" Color="#B9BAC5" />
    <SolidColorBrush x:Key="SubtleText" Color="#848B91" />

    <!-- Tree / list interaction -->
    <SolidColorBrush x:Key="TreeItemHover" Color="#262A30" />
    <SolidColorBrush x:Key="TreeItemSelected" Color="#2E353D" />

    <!-- Tabs & editor chrome -->
    <SolidColorBrush x:Key="TabStripBackground" Color="#252526" />
    <SolidColorBrush x:Key="EditorTabInactiveBackground" Color="#252526" />
    <SolidColorBrush x:Key="EditorTabActiveBackground" Color="#181818" />
    <SolidColorBrush x:Key="EditorTabHoverBackground" Color="#2E353D" />
    <SolidColorBrush x:Key="EditorTabBorder" Color="#1E1E1E" />
    <SolidColorBrush x:Key="EditorTabMutedForeground" Color="#9CA0A8" />
    <SolidColorBrush x:Key="EditorTabBadgeBackground" Color="#333333" />
    <SolidColorBrush x:Key="EditorTabCloseGlyph" Color="#C5C5C5" />
    <SolidColorBrush x:Key="EditorTabCloseHoverBackground" Color="#4B4B4B" />

    <!-- Overlay scrim (modal backdrops) -->
    <SolidColorBrush x:Key="OverlayScrim" Color="#80000000" />

    <!-- Focus ring -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#990E8BDF" />

    <!-- Elevation (BoxShadow values) -->
    <BoxShadows x:Key="ElevationLow">0 1 3 0 #20000000</BoxShadows>
    <BoxShadows x:Key="ElevationMedium">0 4 12 0 #40000000</BoxShadows>
    <BoxShadows x:Key="ElevationHigh">0 8 24 0 #50000000</BoxShadows>

    <!-- Chapter Status Colors -->
    <SolidColorBrush x:Key="StatusOutline" Color="#6C7086" />
    <SolidColorBrush x:Key="StatusFirstDraft" Color="#FAB387" />
    <SolidColorBrush x:Key="StatusRevised" Color="#89B4FA" />
    <SolidColorBrush x:Key="StatusEdited" Color="#A6E3A1" />
    <SolidColorBrush x:Key="StatusFinal" Color="#94E2D5" />

</ResourceDictionary>