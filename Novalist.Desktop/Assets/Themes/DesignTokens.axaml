<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== SPACING SCALE ===== -->
    <x:Double x:Key="SpacingNone">0</x:Double>
    <x:Double x:Key="SpacingTightest">2</x:Double>
    <x:Double x:Key="SpacingTighter">4</x:Double>
    <x:Double x:Key="SpacingSmall">6</x:Double>
    <x:Double x:Key="SpacingMedium">8</x:Double>
    <x:Double x:Key="SpacingNormal">10</x:Double>
    <x:Double x:Key="SpacingLarge">12</x:Double>
    <x:Double x:Key="SpacingXL">16</x:Double>
    <x:Double x:Key="SpacingXXL">20</x:Double>

    <!-- ===== CORNER RADIUS SCALE ===== -->
    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">8</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">10</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>


    <!-- ===== TYPOGRAPHY SCALE (SIZE + WEIGHT) ===== -->
    <!-- Titles / Section headers -->
    <x:Double x:Key="FontSizeTitleSmall">14</x:Double>
    <x:Double x:Key="FontSizeTitle">16</x:Double>
    <FontWeight x:Key="FontWeightTitle">SemiBold</FontWeight>

    <!-- Body -->
    <x:Double x:Key="FontSizeBodySmall">11</x:Double>
    <x:Double x:Key="FontSizeBody">12</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">13</x:Double>

    <!-- Captions / Labels -->
    <x:Double x:Key="FontSizeCaption">9</x:Double>
    <x:Double x:Key="FontSizeTiny">8</x:Double>

</ResourceDictionary>