<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Extensions.AiAssistant.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Novalist.Extensions.AiAssistant.Views.StoryAnalysisView"
             x:DataType="vm:StoryAnalysisViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource ExplorerBackground}"
                Padding="16,12"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="Story Analysis"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NormalText}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Cancel"
                            Command="{Binding CancelAnalysisCommand}"
                            IsVisible="{Binding IsAnalysing}"
                            Classes="ribbonButton"
                            Padding="12,6"
                            FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Chapter Selection + Action Buttons -->
        <Border Grid.Row="1"
                Padding="16,8"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableChapters}"
                          SelectedItem="{Binding SelectedChapter}"
                          HorizontalAlignment="Stretch"
                          FontSize="13"
                          Padding="8,6" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Analyse Chapter"
                            Command="{Binding AnalyseCurrentChapterCommand}"
                            IsVisible="{Binding IsAnalysing, Converter={x:Static BoolConverters.Not}}"
                            Classes="ribbonButton"
                            Padding="12,6"
                            FontSize="12" />
                    <Button Content="Analyse Whole Story"
                            Command="{Binding AnalyseWholeStoryCommand}"
                            IsVisible="{Binding IsAnalysing, Converter={x:Static BoolConverters.Not}}"
                            Classes="ribbonButton"
                            Padding="12,6"
                            FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <Border Grid.Row="2"
                Padding="16,8"
                IsVisible="{Binding IsAnalysing}">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding ProgressText}"
                           FontSize="12"
                           Foreground="{DynamicResource DimText}" />
                <ProgressBar Minimum="0"
                             Maximum="{Binding ProgressTotal}"
                             Value="{Binding ProgressCurrent}"
                             Height="4" />
            </StackPanel>
        </Border>

        <!-- Filter Tabs -->
        <Border Grid.Row="3"
                Padding="16,6"
                IsVisible="{Binding HasResults}"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Scene filter (right side) -->
                <StackPanel Orientation="Horizontal" Spacing="6"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasMultipleScenes}">
                    <TextBlock Text="Scene:"
                               FontSize="11"
                               Foreground="{DynamicResource DimText}"
                               VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SceneFilterOptions}"
                              SelectedItem="{Binding SelectedSceneOption}"
                              FontSize="11"
                              Padding="6,3"
                              MinWidth="140" />
                </StackPanel>

                <!-- Type filter buttons (left side) -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="All"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="all"
                        Classes="ribbonButtonSmall"
                        Classes.active="{Binding FilterType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=all}"
                        Padding="8,4" FontSize="11" />
                <Button Content="🔗 References"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="reference"
                        Classes="ribbonButtonSmall"
                        Classes.active="{Binding FilterType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=reference}"
                        Padding="8,4" FontSize="11" />
                <Button Content="⚠ Inconsistencies"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="inconsistency"
                        Classes="ribbonButtonSmall"
                        Classes.active="{Binding FilterType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=inconsistency}"
                        Padding="8,4" FontSize="11" />
                <Button Content="💡 Suggestions"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="suggestion"
                        Classes="ribbonButtonSmall"
                        Classes.active="{Binding FilterType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=suggestion}"
                        Padding="8,4" FontSize="11" />
                <Button Content="📊 Scene Stats"
                        Command="{Binding SetFilterCommand}"
                        CommandParameter="scene_stats"
                        Classes="ribbonButtonSmall"
                        Classes.active="{Binding FilterType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=scene_stats}"
                        Padding="8,4" FontSize="11" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Results -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,8">
            <StackPanel Spacing="6">
                <!-- Streaming log (during analysis) -->
                <Expander Header="Raw output"
                          IsVisible="{Binding IsAnalysing}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          FontSize="11"
                          Padding="4">
                    <ScrollViewer x:Name="RawOutputScroll"
                                  MaxHeight="200"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <SelectableTextBlock Text="{Binding StreamingLog}"
                                   TextWrapping="Wrap"
                                   MaxWidth="{Binding #RawOutputScroll.Viewport.Width}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DimText}" />
                    </ScrollViewer>
                </Expander>

                <!-- Thinking output (during analysis) -->
                <Expander Header="Thinking"
                          IsVisible="{Binding IsAnalysing}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          FontSize="11"
                          Padding="4">
                    <ScrollViewer x:Name="ThinkingScroll"
                                  MaxHeight="200"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <SelectableTextBlock Text="{Binding StreamingThinking}"
                                   TextWrapping="Wrap"
                                   MaxWidth="{Binding #ThinkingScroll.Viewport.Width}"
                                   FontSize="11"
                                   Foreground="{DynamicResource DimText}" />
                    </ScrollViewer>
                </Expander>

                <!-- Findings list -->
                <ItemsControl ItemsSource="{Binding FilteredFindings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AnalysisFindingItem">
                            <Border Padding="12,8"
                                    Margin="0,2"
                                    CornerRadius="6"
                                    Background="{DynamicResource ExplorerBackground}">
                                <StackPanel Spacing="4">
                                    <DockPanel>
                                        <TextBlock Text="{Binding TypeIcon}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NormalText}"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource NormalText}"
                                               TextWrapping="Wrap"
                                               Margin="22,0,0,0" />
                                    <TextBlock Text="{Binding Excerpt, StringFormat='&quot;{0}&quot;'}"
                                               FontSize="11"
                                               FontStyle="Italic"
                                               Foreground="{DynamicResource DimText}"
                                               TextWrapping="Wrap"
                                               Margin="22,0,0,0"
                                               IsVisible="{Binding HasExcerpt}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                Margin="22,2,0,0">
                                        <Border CornerRadius="3"
                                                Padding="4,1"
                                                Background="#2095a5a6"
                                                IsVisible="{Binding HasEntity}">
                                            <TextBlock Text="{Binding EntityName}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource DimText}" />
                                        </Border>
                                        <Border CornerRadius="3"
                                                Padding="4,1"
                                                Background="#2095a5a6"
                                                IsVisible="{Binding HasScene}">
                                            <TextBlock Text="{Binding SceneName}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource DimText}" />
                                        </Border>
                                    </StackPanel>

                                    <!-- Scene Stats details -->
                                    <Border IsVisible="{Binding IsSceneStats}"
                                            Margin="22,4,0,0"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            Background="#1095a5a6">
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                              ColumnSpacing="12" RowSpacing="2">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="POV:" FontSize="11" Foreground="{DynamicResource DimText}" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ScenePov}" FontSize="11" Foreground="{DynamicResource NormalText}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Emotion:" FontSize="11" Foreground="{DynamicResource DimText}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SceneEmotion}" FontSize="11" Foreground="{DynamicResource NormalText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Intensity:" FontSize="11" Foreground="{DynamicResource DimText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SceneIntensity}" FontSize="11" Foreground="{DynamicResource NormalText}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Conflict:" FontSize="11" Foreground="{DynamicResource DimText}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SceneConflict}" FontSize="11" Foreground="{DynamicResource NormalText}" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock Text="{Binding ProgressText}"
                           IsVisible="{Binding HasResults, Converter={x:Static BoolConverters.Not}}"
                           FontSize="13"
                           Foreground="{DynamicResource DimText}"
                           HorizontalAlignment="Center"
                           Margin="0,40" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
